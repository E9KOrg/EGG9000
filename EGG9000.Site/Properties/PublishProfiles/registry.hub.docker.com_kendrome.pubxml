<?xml version="1.0" encoding="utf-8"?>
<!-- https://go.microsoft.com/fwlink/?LinkID=208121. -->
<Project>
  <PropertyGroup>
    <WebPublishMethod>Docker</WebPublishMethod>
    <PublishProvider>ContainerRegistry</PublishProvider>
    <DockerPublish>true</DockerPublish>
    <RegistryUrl>https://registry.hub.docker.com/kendrome</RegistryUrl>
    <UserName>kendrome</UserName>
    <PublishImageName>kendrome/egg9000site</PublishImageName>
    <PublishImageTag>$([System.DateTime]::Now.ToString('yyyyMMdd-HHmmss'))</PublishImageTag>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <RuntimeIdentifier>linux-x64</RuntimeIdentifier>
    <_TargetId>DockerContainerRegistry</_TargetId>
  </PropertyGroup>
</Project>