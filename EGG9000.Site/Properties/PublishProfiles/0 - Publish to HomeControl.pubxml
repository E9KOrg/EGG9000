<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <DeleteExistingFiles>false</DeleteExistingFiles>
    <ExcludeApp_Data>false</ExcludeApp_Data>
    <LaunchSiteAfterPublish>true</LaunchSiteAfterPublish>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <PublishProvider>FileSystem</PublishProvider>
    <PublishUrl>\\homecontrol\C\EGG9000.Site</PublishUrl>
    <WebPublishMethod>FileSystem</WebPublishMethod>
    <SiteUrlToLaunchAfterPublish />
    <TargetFramework>net9.0</TargetFramework>
    <ProjectGuid>e07a294a-6b62-4e21-864a-ea78b3ac8cd5</ProjectGuid>
    <SelfContained>false</SelfContained>
    <EnableMSDeployAppOffline>true</EnableMSDeployAppOffline>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PipelineDependsOn>
      CustomAfterPublish;
      $(PipelineDependsOn);
    </PipelineDependsOn>
  </PropertyGroup>

  <Target Name="CustomAfterPublish">
    <Message Text="********************************** CustomAfterPublish ***********************************" Importance="high"/>
    <Exec Command="swapsites.bat" />
  </Target>
</Project>