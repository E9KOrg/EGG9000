@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<h4>@ViewData["Title"]</h4>
<partial name="_StatusMessage" model="Model.StatusMessage" />
<div class="row">
    <div class="col-md-6">
        <form id="profile-form" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Username"></label>
                <input asp-for="Username" class="form-control" />
            </div>
            <div class="form-check">
                <input id="darkModeEnable" class="form-check-input" type="checkbox">
                <label class="form-check-label">Enable Dark Mode (beta)</label>
            </div>
            <hr />
            @*<div class="form-group">
                <label asp-for="Input.PhoneNumber"></label>
                <input asp-for="Input.PhoneNumber" class="form-control" />
                <span asp-validation-for="Input.PhoneNumber" class="text-danger"></span>
            </div>*@
            <div class="form-check">
                <input class="form-check-input" type="checkbox" asp-for="Input.DMOnShipReturn">
                <label class="form-check-label" asp-for="Input.DMOnShipReturn"></label>
                <span asp-validation-for="Input.DMOnShipReturn" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.ShipReturnMinutes"></label>
                <input asp-for="Input.ShipReturnMinutes" class="form-control" />
                <span asp-validation-for="Input.ShipReturnMinutes" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Input.ShipReturnStillFuelingMinutes"></label>
                <input asp-for="Input.ShipReturnStillFuelingMinutes" class="form-control" />
                <span asp-validation-for="Input.ShipReturnStillFuelingMinutes" class="text-danger"></span>
            </div>
            <br />
            <button id="update-profile-button" type="submit" class="btn btn-primary">Save</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
      $(function() {
        $('#darkModeEnable').change(function() {
            console.log("Trigged.")
            if ($('#darkModeEnable').is(":checked")) {
                $('body').addClass("bootstrap-dark");
                $('body').removeClass("bootstrap");
                Cookies.set('Egg9000Theme', 'bootstrap-dark');
            }
            else {
                $('body').addClass("bootstrap");
                $('body').removeClass("bootstrap-dark");
                Cookies.set('Egg9000Theme', 'bootstrap');
            }
        })
      })
    </script>
}