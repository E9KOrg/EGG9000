@inject DiscordSocketClient DiscordClient
@model (int Index, CustomBackup Backup,  List<Coop> JoinedCoops, List<Contract> Contracts)

@{
    string properCaseAndSuffix(string inputString, int number){
        var suffix = (number == 0 || number > 1) ? "s" : "";
        return inputString.FirstCharToUpper() + suffix;
    }

    string properSpacing(string input) {
        StringBuilder result = new StringBuilder(input.Length * 2);
        result.Append(input[0]); // Add the first character as is
        for (int i = 1; i < input.Length; i++) {
            if (char.IsUpper(input[i])) result.Append(' ');
            result.Append(input[i]);
        }
        return result.ToString();
    }

    void artifactTemplate(EggIncArtifactInstance artifact) {
                <tr>
                    <td>@artifact.Artifact</td>
                    @if (artifact.Boost == EggIncBoostTypeEnum.HostArtifactsOnElightenment) {
                        <td>@Math.Round((artifact.Value) * 100)%</td>
            } else if(artifact.Boost == EggIncBoostTypeEnum.ResearchCost) {
                        <td>-@artifact.Value</td>
            } else if (artifact.Additive) {
                        <td>+@artifact.Value</td>
            } else if (+artifact.Value < 2) {
                        <td>+@Math.Round((artifact.Value - 1) * 100)%</td>
            } else {
                        <td>@(artifact.Value)x</td>
            }
                    <td>@properSpacing(artifact.Boost.ToString())</td>
        </tr>
    }

    string getShipEmoji(Spaceship ship) {
        var shipEmoji = ship switch {
            Spaceship.ChickenOne => "807223532747620373",
            Spaceship.ChickenNine => "801748829212508161",
            Spaceship.ChickenHeavy => "801748846455554088",
            Spaceship.Bcr => "801748795498430464",
            Spaceship.MilleniumChicken => "801748939354931200",
            Spaceship.CorellihenCorvette => "801748884061159465",
            Spaceship.Galeggtica => "801748910607171644",
            Spaceship.Chickfiant => "801748897243987978",
            Spaceship.Voyegger => "801748952814845962",
            Spaceship.Henerprise => "801748924146384906",
            Spaceship.Atreggies => "1215022229826314380",
            _ => ""
        };
        if(shipEmoji == "") {
            return shipEmoji;
        }
        var shipEmojiLink = "https://cdn.discordapp.com/emojis/" + shipEmoji + ".png?v=1";
        return shipEmojiLink;
    }

    int index = Model.Index;

    string fuelAmountsToText(double value){
        if (value >= 1_000_000_000_000) { // Trillions or more
            return (value / 1_000_000_000_000).ToString("N1") + "T";
        } else if (value >= 1_000_000_000) { // Billions
            return (value / 1_000_000_000).ToString("N1") + "B";
        } else if (value >= 1_000_000) { // Millions
            return (value / 1_000_000).ToString("N1") + "M";
        } else {
            return value.ToString("N2");
        }
    }

    string durationColor(DurationType duration){
        return duration switch {
            DurationType.Tutorial => "gray",
            DurationType.Short => "#13589c",
            DurationType.Long => "purple",
            DurationType.Epic => "darkorange",
            _ => "gray"
        };
    }

    List<SpaceMission> iterableMissions = [
        .. Model.Backup?.SpaceMissions ?? new List<SpaceMission>(),
    ];

    if (Model.Backup?.FuelingMission is not null) iterableMissions.Add(Model.Backup.FuelingMission);
}

<script type="text/javascript">
    var isMobileCS = false;
    if (window.innerWidth <= 768) { // You can adjust the threshold for mobile screens
        isMobileCS = true;
    }

    function formatEpochToTime(epochSeconds, full) {
        // Calculate the difference between the epoch time and the current time in seconds
        var timeDifference = epochSeconds - Math.floor(Date.now() / 1000);

        if (timeDifference < 0) {
            // If the time is in the past, invert to assume counting up.
            //return "0s";
            timeDifference *= -1;
        }

        var days = Math.floor(timeDifference / 86400); // 86400 seconds in a day
        var hours = Math.floor((timeDifference % 86400) / 3600); // 3600 seconds in an hour
        var minutes = Math.floor((timeDifference % 3600) / 60); // 60 seconds in a minute
        var seconds = timeDifference % 60; // 60 seconds in a minute

        // Format the result as "XdXhXm"
        var result = ("" + (days > 0 ? `${days}d` : "") + (hours > 0 ? `${hours}h` : "") + ((minutes > 0 && (days == 0 && hours < 10 || full)) ? `${minutes}m` : "") + ((seconds > 0 && ((minutes < 10 && hours == 0 && days == 0) || full)) ? `${seconds}s` : "")) ?? "0s";
        if (result == "") result = "0s"; // If the time is empty, display "0s"

        return result;
    }
</script>

