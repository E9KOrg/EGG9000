<script type="text/javascript">
    var timeState = 'no';
    var ctrlReleaseHandled = false;
    var index = @index;

    var isMobile = (window.innerWidth < 768);
    if (isMobile) {
        document.querySelectorAll('[id*="do-tt"]').forEach(el => { el.style.height = '0px'; });
        document.querySelectorAll('[id*="do-tt"]').forEach(el => { el.style.visibility = 'hidden'; });
        document.querySelectorAll('[id*="do-tt"]').forEach(el => { el.style.display = 'none'; });
        document.querySelectorAll('[id*="shipInfoContainer"]').forEach(el => { el.style.flexDirection = 'column'; });
        document.querySelectorAll('[id*="asc-planner-cont"]').forEach(el => { el.style.marginLeft = '10px'; });
        document.querySelectorAll('[id*="ship-level-container-"]').forEach(el => { el.style.width = '100%' });
        document.querySelectorAll('[dataMaxed="True"]').forEach(el => { el.style.display = 'none'; });
    } else {
        document.querySelectorAll('[id*="mo-tt"]').forEach(el => { el.style.height = '0px'; });
        document.querySelectorAll('[id*="mo-tt"]').forEach(el => { el.style.visibility = 'hidden'; });
        document.querySelectorAll('[id*="mo-tt"]').forEach(el => { el.style.display = 'none'; });
        document.querySelectorAll('[id*="shipInfoContainer"]').forEach(el => { el.style.flexDirection = 'row'; });
    }
    
    function properCaseAndSuffix(inputString, number) {
        const suffix = (number == 0 || number > 1) ? 's' : '';
        return inputString.charAt(0).toUpperCase() + inputString.slice(1) + suffix;
    }

    document.addEventListener("keydown", function (event) {
        if (event.ctrlKey) ctrlReleaseHandled = false;
    });

    function toggleShipTimes(){
        const elementsLaunched = Array.from(document.querySelectorAll('[id*="-launched"]'));
        const elementsMaxLvl = Array.from(document.querySelectorAll('[id*="-maxlvl"]'));
        const elementsNextLvl = Array.from(document.querySelectorAll('[id*="-nextlvl"]'));
        const elements = elementsLaunched.concat(elementsMaxLvl, elementsNextLvl);
        switch (timeState) {
            case 'yes':
                timeState = 'no';
                elements.forEach(element => {
                    if (element.nodeName == 'SPAN') {
                        const elementId = element.id.toString();
                        const durationType = elementId.split("-")[1];
                        const durationString = properCaseAndSuffix(durationType, parseInt(element.intVal));
                        element.textContent = element.getAttribute('intval') + ' ' + durationString;
                    }
                });
                break;
            case 'no':
                timeState = 'yes';
                elements.forEach(element => {
                    if (element.nodeName == 'SPAN') element.textContent = element.getAttribute('timeval') + ' (' + element.getAttribute('intval') + ')';
                });
                break;
        }
    }

    /* When control is released */
    document.addEventListener("keyup", function (event) {
        if (!event.ctrlKey && !ctrlReleaseHandled) {
            ctrlReleaseHandled = true;
            toggleShipTimes();
        }
    });

    function durationSelectionChanged(el) {
        if (el == null || el.id == null) return;

        var shipName = el.id.split('-')[0];
        index = el.id.split('-')[el.id.split('-').length - 1];
        console.log("index: " + index);
        var newValue = el.value;

        var numNeededSpan = document.getElementById(shipName + '-number-needed-asc-' + index);
        numNeededSpan.textContent = numNeededSpan.getAttribute('data-' + newValue);

        var timeNeededSpan = document.getElementById(shipName + '-time-needed-asc-' + index);
        timeNeededSpan.textContent = timeNeededSpan.getAttribute('dt-' + newValue);

        var newColorClass = '';
        switch(newValue){
            case 'extended':
                newColorClass = 'orange-text'
                break;
            case 'standard':
                newColorClass = 'purple-text'
                break;
            default:
            case 'short':
                newColorClass = 'blue-text';
                break;
        }
        timeNeededSpan.classList = newColorClass;
        numNeededSpan.classList = newColorClass;
        el.classList = newColorClass;

        //Re-calc total times
        reSumTimes(index);
    }

    function reSumTimes(index){

        console.log("Summming for index " + index);

        var times = [];

        var idQuery = "-time-needed-asc-" + index;
        var timeEls = document.querySelectorAll('[id*="' + idQuery + '"]');

        if(timeEls.length == 0) {
            console.log("Time els is empty");
            var el2 = document.getElementById('total-asc-time-' + index);
            if(el2 == undefined) return;
            else el2.textContent = 'Maxed';
            return;
        }

        timeEls.forEach(el => {
            if(el.textContent !== '0m')
                times.push(el.textContent);
        });

        const summedTimesStr = sumTime(times);
        document.getElementById('total-asc-time-' + index).textContent = summedTimesStr;
    }

    function sumTime(timeStrings) {
        let totalSeconds = 0;
        for (let i = 0; i < timeStrings.length; i++) {
            const timeString = timeStrings[i].trim();
            const days = parseInt(timeString.match(/\d+d/)?.[0]?.slice(0, -1) ?? 0);
            const hours = parseInt(timeString.match(/\d+h/)?.[0]?.slice(0, -1) ?? 0);
            const minutes = parseInt(timeString.match(/\d+m/)?.[0]?.slice(0, -1) ?? 0);
            totalSeconds += (days * 24 * 60 * 60) + (hours * 60 * 60) + (minutes * 60);
        }
        const days = Math.floor(totalSeconds / (24 * 60 * 60));
        const hours = Math.floor((totalSeconds % (24 * 60 * 60)) / (60 * 60));
        const minutes = Math.floor((totalSeconds % (60 * 60)) / 60);
        return `${days}d${hours}h${minutes}m`;
    }

    document.addEventListener("DOMContentLoaded", function () {
        reSumTimes(0);
        reSumTimes(1);
        reSumTimes(2);
        reSumTimes(3);
        reSumTimes(4);
        reSumTimes(5);
    });

</script>



@for (var i = 0; i < Model.Backup.Farms.Count; i++) {
    var farm = Model.Backup.Farms[i];


    if (farm.FarmType != Ei.FarmType.Empty) {
        var coop = Model.JoinedCoops.FirstOrDefault(x => x.Name.Equals(farm.CoopId, StringComparison.InvariantCultureIgnoreCase));
        var farmStats = farm.WithStats(Model.Backup, coop);
        <div style="display: inline-block;" class="card">
            @if (farm.FarmType == Ei.FarmType.Home) {
                <h4 class="card-header"><img src="/images/Egg_@((int)farm.EggType).png" /> Home Farm</h4>
            } else if (farm.ContractId != null) {
                <h4 class="card-header"><img src="/images/Egg_@((int)farm.EggType).png" /> @Model.Contracts.FirstOrDefault(x => x.ID == farm.ContractId)?.Name</h4>
            } else {
                <h4 class="card-header">Error Finding Contract @farm.ContractId</h4>
            }
            <div class="card-body">
                <div style="display: inline-block;">
                    Chickens: @farm.NumChickens.ToEggString()
                </div>
                <div>
                    Egg Rate: @((farmStats.EggLayingRate * 60).ToEggString(true))/m
                </div>
                <div>
                    Max Shipping Rate: @((farmStats.MaxShippingRate * 60).ToEggString(true))/m
                </div>
                <div>
                    Current Shipping Rate: @((farmStats.CurrentShippingRate * 60).ToEggString(true))/m (@((farmStats.CurrentShippingRate).ToEggString(true, 3))/s)
                </div>
                <div>
                    Hab Space: @farmStats.HabSpace.ToEggString()
                </div>
                <div>
                    Base Internal Hatchery: @Research.InternalHatchery(farm, Model.Backup.EpicResearch)
                </div>
                <div id="@Model.Backup.EggIncId">
                    Internal Hatchery: @farmStats.InternalHatchery/m
                </div>
                <div>
                    Silo Time: @(Research.GetTotalSiloCapacity(Model.Backup) * farm.SilosOwned / 60)
                </div>
                @if (coop is not null) {
                    <div>
                        Coop:
                        <a href="/coop/@farm.ContractId/@(farm.CoopId ?? coop?.Name)">
                            @(farm.CoopId ?? coop?.Name)
                        </a>
                        @if (coop is not null && !coop.DeletedChannel) {
                            <a href="discord://discordapp.com/channels/@coop.OverflowGuildId/@coop.DiscordChannelId/"><img src="/images/discordicon.png" style="max-height: 1em;" /></a>
                        }
                    </div>
                }
            </div>
            <div class="card-body" style="padding-bottom: 0;">
                <h6>Artifacts</h6>
            </div>
            <table class="table table-sm" style="margin-bottom: 0;">
                @if (farm.Artifacts.Count == 0) {
                    <tr><td><i>No Artifacts</i></td></tr>
                }
                @foreach (var artifact in farm.Artifacts) {
                    artifactTemplate(artifact);
                    @if (artifact.Stones != null && artifact.Stones.Count > 0) {
                        <td colspan="99" style="padding-left: 10px; ">
                            <table>
                                @foreach (var stone in artifact.Stones) {
                                    artifactTemplate(stone);
                                }
                            </table>
                        </td>
                    }
                }
            </table>
        </div>
    }
}