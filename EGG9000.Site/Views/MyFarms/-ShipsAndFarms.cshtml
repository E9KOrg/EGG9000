@using Discord.WebSocket;
@using EGG9000.Site.Controllers;
@using System.Globalization;
@using static EGG9000.Common.Coops.ArtifactCombos;
@inject DiscordSocketClient DiscordClient
@model (int Index, CustomBackup Backup,  List<Coop> JoinedCoops, List<Contract> Contracts)

@{
    string properCaseAndSuffix(string inputString, int number){
        var suffix = (number == 0 || number > 1) ? "s" : "";
        return inputString.FirstCharToUpper() + suffix;
    }

    void artifactTemplate(EggIncArtifactInstance artifact) {
        <tr>
            <td>@artifact.Artifact</td>
            @if (artifact.Boost == EggIncBoostTypeEnum.HostArtifactsOnElightenment) {
                <td>@Math.Round((artifact.Value) * 100)%</td>
            } else if (artifact.Additive) {
                <td>+@artifact.Value</td>
            } else if (+artifact.Value < 2) {
                <td>+@Math.Round((artifact.Value - 1) * 100)%</td>
            } else {
                <td>@(artifact.Value)x</td>
            }
            <td>@artifact.Boost</td>
        </tr>
    }

    string getShipEmoji(Ei.MissionInfo.Types.Spaceship ship) {
        var shipEmoji = ship switch {
            Ei.MissionInfo.Types.Spaceship.ChickenOne => "807223532747620373",
            Ei.MissionInfo.Types.Spaceship.ChickenNine => "801748829212508161",
            Ei.MissionInfo.Types.Spaceship.ChickenHeavy => "801748846455554088",
            Ei.MissionInfo.Types.Spaceship.Bcr => "801748795498430464",
            Ei.MissionInfo.Types.Spaceship.MilleniumChicken => "801748939354931200",
            Ei.MissionInfo.Types.Spaceship.CorellihenCorvette => "801748884061159465",
            Ei.MissionInfo.Types.Spaceship.Galeggtica => "801748910607171644",
            Ei.MissionInfo.Types.Spaceship.Chickfiant => "801748897243987978",
            Ei.MissionInfo.Types.Spaceship.Voyegger => "801748952814845962",
            Ei.MissionInfo.Types.Spaceship.Henerprise => "801748924146384906",
            _ => ""
        };
        if(shipEmoji == "") {
            return shipEmoji;
        }
        var shipEmojiLink = "https://cdn.discordapp.com/emojis/" + shipEmoji + ".png?v=1";
        return shipEmojiLink;
    }

    int index = Model.Index;
}

<script type="text/javascript">
    var isMobileCS = false;
    if (window.innerWidth <= 768) { // You can adjust the threshold for mobile screens
        isMobileCS = true;
    }
</script>

<style>
    .GoldenStar {
        color: gold;
    }

    .GrayStar {
        color: gray;
    }

    .tooltip-custom {
        position: relative;
        display: inline-block;
    }

        .tooltip-custom:hover .tooltiptext-custom {
            display: inline-block;
            z-index: 2;
            position: absolute;
            bottom: 25px; /* Adjust this value as needed */
            left: 50%;
            transform: translateX(-50%); /* Center the tooltip */
        }

    .tooltiptext-custom {
        display: none;
        background-color: rgba(255, 255, 255, 0.95);
        border: 1px solid #ccc;
        padding: 10px;
        border-radius: 4px;
        white-space: nowrap;
        text-align: center; /* Center the text within the tooltip */
        position: absolute;
    }

    .gray-text-half-margin, .gray-text {
        color: lightgray;
    }

    .orange-text {
        color: darkorange;
    }

    .purple-text {
        color: purple;
    }

    .blue-text {
        color: blue;
    }

    .gray-text, .orange-text, .purple-text, .blue-text {
        display: inline-block;
        margin-right: 10px;
    }

    .gray-text-half-margin {
        display: inline-block;
        margin-right: 5px;
    }

    .speech-bubble {
        position: relative;
        padding: 10px; /* Adjust the padding to your preference */
        margin: 10px auto; /* Center the bubble horizontally */
        border-radius: 5px; /* Rounded corners for the bubble */
    }

    /* Create the triangle */
    .speech-bubble :after {
        content: "";
        position: absolute;
        top: 100%;
        left: 50%;
        margin-left: -15px; /* Half of the triangle's width */
        border-width: 15px; /* Adjust the size of the triangle */
        border-style: solid;
        border-color: #ccc transparent transparent transparent;
    }

    .ship-info-container {
        display: flex;
    }

    .ship-info-item {
        flex: 1;
    }

</style>

<div id="shipsDiv" class="ship-container">
    @foreach (var mission in Model.Backup.SpaceMissions ?? new List<SpaceMission>()) {
        var returns = DateTimeOffset.FromUnixTimeSeconds((long)mission.StartTime + (long)mission.DurationSeconds);


        var shipEmojiLink = getShipEmoji(mission.Ship);
        <div class="ship-item card" style="display: inline-block; text-align: center; margin: 10px; padding-top: 10px">
            @if (shipEmojiLink != "") {
                <img src="@((shipEmojiLink))" style="max-height: 40px">
            }
            <h4 class="card-header">@mission.Ship.ToString().Replace("_", " ")</h4>
            <div class="card-body">
                <div>Status: @mission.Status</div>
                @switch (mission.Status) {
                    case Ei.MissionInfo.Types.Status.Fueling:

                        var fuelTargets = Ei.MissionInfo.GetFuelTargets(mission.Ship, mission.Duration);
                        var needsFuel = mission == null || fuelTargets.Any(ft => ft.Value > (mission.Fuels.FirstOrDefault(f => f.Egg == ft.Key)?.Amount ?? 0));
                        <div>Needs Fuel: @needsFuel</div>
                        foreach (var fuel in mission.Fuels) {
                            var target = fuelTargets[fuel.Egg];
                            var percent = fuel.Amount / target * 100;
                            <div>
                                @fuel.Egg.ToString(): @Math.Round(percent)% full
                            </div>
                        }
                        break;
                    case Ei.MissionInfo.Types.Status.Exploring:
                    case Ei.MissionInfo.Types.Status.Returned:
                        if (returns < DateTimeOffset.Now) {
                            <div>Returned: @((returns - DateTimeOffset.Now).Humanize(2).ShortenTime()) ago</div>
                        } else {
                            <div>Returns: @((returns - DateTimeOffset.Now).Humanize(2).ShortenTime())</div>
                        }
                        break;
                }
                <div>Capacity: @((mission.Capacity))</div>
                <!-- Only quintillion (4) and above can be targeted ships-->
                @if (((int)mission?.Ship >= 4) && mission?.Targeting != null) {
                    @switch (mission?.Targeting) {
                        case Ei.ArtifactSpec.Types.Name.Unknown:
                            <div>Targeting: None</div>
                            break;
                        default:
                            <div>Targeting: @((mission.Targeting))</div>
                            break;
                    }
                }
            </div>
        </div>
    }
</div>

<div id="shipInfoContainer-@index" class="ship-info-container">
    <div id="ship-level-container-@index" style="margin-left: 10px; width:60%; display: block;">
        <table id="ship-level-table" class="table card table-sm" style="width: 100%; table-layout: auto; display: table;">
            <thead>
                <tr>
                    <th style="text-align: center;">Ship</th>
                    <th>Stars</th>
                    <th>Next Level</th>
                    <th>Max Level</th>
                    <th>Launches</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ship in MissionHelpers.MaxShipLevels) {
                    var currentStars = Model.Backup.GetShipLevel(ship.Key);
                    var shipEmojiLink = getShipEmoji(ship.Key);
                    <tr id="@ship.Key-overall-row" style="height: 38px;">
                        <td align="center">
                            @if (shipEmojiLink != "") {
                                <img src="@((shipEmojiLink))" title="@MissionHelpers.GetProperShipName(ship.Key)" style="max-height:20px;">
                            }
                        </td>
                        <td>
                            @for (var i = 0; i < ship.Value; i++) {
                                if (i < currentStars){
                                    <span class="Star GoldenStar">★</span>
                                } else {
                                    <span class="Star GrayStar">★</span>
                                }
                            }
                        </td>
                        <td>
                            @if (Model.Backup.GetShipProgressTotal(ship.Key) != 1) {
                                <span class="tooltip-custom">
                                    @Model.Backup.GetShipProgressNextLevel(ship.Key).ToString("P0")
                                    <span class="tooltiptext-custom speech-bubble">
                                        @{
                                            var shipsToNext = Model.Backup.LaunchShipsToNext(ship.Key);
                                            var shortsToNext = shipsToNext.ContainsKey(Ei.MissionInfo.Types.DurationType.Short) ? shipsToNext[Ei.MissionInfo.Types.DurationType.Short] : 0;
                                            var standardsToNext = shipsToNext.ContainsKey(Ei.MissionInfo.Types.DurationType.Long) ? shipsToNext[Ei.MissionInfo.Types.DurationType.Long] : 0;
                                            var extendedsToNext = shipsToNext.ContainsKey(Ei.MissionInfo.Types.DurationType.Epic) ? shipsToNext[Ei.MissionInfo.Types.DurationType.Epic] : 0;

                                            var shortsTimeNext = Model.Backup.GetShipTime(ship.Key, Ei.MissionInfo.Types.DurationType.Short, shortsToNext);
                                            var standardsTimeNext = Model.Backup.GetShipTime(ship.Key, Ei.MissionInfo.Types.DurationType.Long, standardsToNext);
                                            var extendedsTimeNext = Model.Backup.GetShipTime(ship.Key, Ei.MissionInfo.Types.DurationType.Epic, extendedsToNext);
                                        }
                                        <span id="@ship.Key-short-nextlvl" timeval="@shortsTimeNext" intval="@shortsToNext" class="blue-text">@shortsToNext @properCaseAndSuffix("Short", shortsToNext)</span><span class="gray-text-half-margin">or</span>
                                        <span id="@ship.Key-standard-nextlvl" timeval="@standardsTimeNext" intval="@standardsToNext" class="purple-text">@standardsToNext @properCaseAndSuffix("Standard", standardsToNext)</span><span class="gray-text-half-margin">or</span>
                                        <span id="@ship.Key-extended-nextlvl" timeval="@extendedsTimeNext" intval="@extendedsToNext" class="orange-text">@extendedsToNext @properCaseAndSuffix("Extended", extendedsToNext)</span>
                                    </span>
                                </span>
                            }
                            else{@("--")}
                        </td>
                        <td>
                            <span class="tooltip-custom">
                                @Model.Backup.GetShipProgressTotal(ship.Key).ToString("P0")
                                @if (Model.Backup.GetShipProgressTotal(ship.Key) != 1){
                                    <span class="tooltiptext-custom speech-bubble">
                                        @{
                                            var shipsToMax = Model.Backup.LaunchShipsToMax(ship.Key);
                                            var shortsToMax = shipsToMax.ContainsKey(Ei.MissionInfo.Types.DurationType.Short) ? shipsToMax[Ei.MissionInfo.Types.DurationType.Short] : 0;
                                            var standardsToMax = shipsToMax.ContainsKey(Ei.MissionInfo.Types.DurationType.Long) ? shipsToMax[Ei.MissionInfo.Types.DurationType.Long] : 0;
                                            var extendedsToMax = shipsToMax.ContainsKey(Ei.MissionInfo.Types.DurationType.Epic) ? shipsToMax[Ei.MissionInfo.Types.DurationType.Epic] : 0;

                                            var shortsTimeMax = Model.Backup.GetShipTime(ship.Key, Ei.MissionInfo.Types.DurationType.Short, shortsToMax);
                                            var standardsTimeMax = Model.Backup.GetShipTime(ship.Key, Ei.MissionInfo.Types.DurationType.Long, standardsToMax);
                                            var extendedsTimeMax = Model.Backup.GetShipTime(ship.Key, Ei.MissionInfo.Types.DurationType.Epic, extendedsToMax);
                                        }
                                        <span id="@ship.Key-short-maxlvl" timeval="@shortsTimeMax" intval="@shortsToMax" class="blue-text">@shortsToMax @properCaseAndSuffix("Short", shortsToMax)</span><span class="gray-text-half-margin">or</span>
                                        <span id="@ship.Key-standard-maxlvl" timeval="@standardsTimeMax" intval="@standardsToMax" class="purple-text">@standardsToMax @properCaseAndSuffix("Standard", standardsToMax)</span><span class="gray-text-half-margin">or</span>
                                        <span id="@ship.Key-extended-maxlvl" timeval="@extendedsTimeMax" intval="@extendedsToMax" class="orange-text">@extendedsToMax @properCaseAndSuffix("Extended", extendedsToMax)</span>
                                    </span>
                                }
                            </span>
                        </td>
                        <td>
                            <span class="tooltip-custom">
                                @Model.Backup.ShipsSent.Where(x => x.ship == ship.Key).Sum(x => x.count)
                                <span class="tooltiptext-custom speech-bubble">
                                    @{
                                        var ships = Model.Backup.ShipsSent.Where(x => x.ship == ship.Key);
                                        var tutorialShips = ships.FirstOrDefault(x => x.type == Ei.MissionInfo.Types.DurationType.Tutorial);
                                        var extendedShips = ships.FirstOrDefault(x => x.type == Ei.MissionInfo.Types.DurationType.Epic);
                                        var standardShips = ships.FirstOrDefault(x => x.type == Ei.MissionInfo.Types.DurationType.Long);
                                        var shortShips = ships.FirstOrDefault(x => x.type == Ei.MissionInfo.Types.DurationType.Short);

                                        var tutorialTimeLaunched = Model.Backup.GetShipTime(ship.Key, Ei.MissionInfo.Types.DurationType.Tutorial, tutorialShips.count);
                                        var shortsTimeLaunched = Model.Backup.GetShipTime(ship.Key, Ei.MissionInfo.Types.DurationType.Short, shortShips.count);
                                        var standardsTimeLaunched = Model.Backup.GetShipTime(ship.Key, Ei.MissionInfo.Types.DurationType.Long, standardShips.count);
                                        var extendedsTimeLaunched = Model.Backup.GetShipTime(ship.Key, Ei.MissionInfo.Types.DurationType.Epic, extendedShips.count);

                                    }
                                    @if (ship.Key == Ei.MissionInfo.Types.Spaceship.ChickenOne) {
                                        <span id="@ship.Key-tutorial-launched" timeval="@tutorialTimeLaunched" intval="@tutorialShips.count" class="gray-text">@tutorialShips.count @properCaseAndSuffix("Tutorial", tutorialShips.count)</span>
                                    }
                                    <span id="@ship.Key-short-launched" timeval="@shortsTimeLaunched" intval="@shortShips.count" class="blue-text">@shortShips.count @properCaseAndSuffix("Short", shortShips.count)</span>
                                    <span id="@ship.Key-standard-launched" timeval="@standardsTimeLaunched" intval="@standardShips.count" class="purple-text">@standardShips.count @properCaseAndSuffix("Standard", standardShips.count)</span>
                                    <span id="@ship.Key-extended-launched" timeval="@extendedsTimeLaunched" intval="@extendedShips.count" class="orange-text">@extendedShips.count @properCaseAndSuffix("Extended", extendedShips.count)</span>
                                </span>
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <span id="do-tt-@index" style="color: #ccc">ℹ️<i>Press CTRL to toggle showing times for ship launches in tooltips.</i></span>
        <button class="btn-primary" id="mo-tt-@index" style="color: #ccc; margin-bottom: 10px;" onclick="toggleShipTimes()"><span>Toggle showing times in tooltips.</span></button>
    </div>
    <div id="asc-planner-cont" style="margin-left: 0px; width: auto"> 
        <table id="asc-planner-table" class="table card table-sm" style="table-layout: auto; display: table;">
            <thead>
                <tr>
                    <th colspan="4">ASC Planner 
                        <span class="tooltip-custom">
                            (❔)
                            <span class="tooltiptext-custom speech-bubble">
                                All-Star-Club, commonly shortened to "ASC", is<br />
                                the name of the community-created achievement<br />
                                for getting completing all <span class="GoldenStar">★</span>s, on all ships.
                            </span>
                        </span>
                    </th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ship in MissionHelpers.MaxShipLevels)
                {
                    var alreadyMaxed = (Model.Backup.GetShipProgressTotal(ship.Key) >= 1);

                    var currentStars = Model.Backup.GetShipLevel(ship.Key);
                    var shipEmojiLink = getShipEmoji(ship.Key);

                    var shipsToMax = Model.Backup.LaunchShipsToMax(ship.Key);
                    var shortsToMax = shipsToMax.ContainsKey(Ei.MissionInfo.Types.DurationType.Short) ? shipsToMax[Ei.MissionInfo.Types.DurationType.Short] : 0;
                    var standardsToMax = shipsToMax.ContainsKey(Ei.MissionInfo.Types.DurationType.Long) ? shipsToMax[Ei.MissionInfo.Types.DurationType.Long] : 0;
                    var extendedsToMax = shipsToMax.ContainsKey(Ei.MissionInfo.Types.DurationType.Epic) ? shipsToMax[Ei.MissionInfo.Types.DurationType.Epic] : 0;

                    var shortsTimeMax = Model.Backup.GetShipTimeRaw(ship.Key, Ei.MissionInfo.Types.DurationType.Short, shortsToMax);
                    var standardsTimeMax = Model.Backup.GetShipTimeRaw(ship.Key, Ei.MissionInfo.Types.DurationType.Long, standardsToMax);
                    var extendedsTimeMax = Model.Backup.GetShipTimeRaw(ship.Key, Ei.MissionInfo.Types.DurationType.Epic, extendedsToMax);

                    <tr id="@ship.Key-asc-row-@index" style="height: 38px;" dataMaxed="@(alreadyMaxed.ToString())">
                        <td id="asc-name-col-@index" align="left" style="padding-left: 5px; font-size: 0.75rem;" dataMaxed="@(alreadyMaxed.ToString())">
                            @MissionHelpers.GetProperShipName(ship.Key)
                        </td>
                        <td dataMaxed="@(alreadyMaxed.ToString())">
                            @if (!alreadyMaxed) {
                                <select class="blue-text" name="@ship.Key-duration-asc-choice-@index" id="@ship.Key-duration-asc-choice-@index" onchange="durationSelectionChanged(this)">
                                    <option value="short" class="blue-text">Short</option>
                                    <option value="standard" class="purple-text">Standard</option>
                                    <option value="extended" class="orange-text">Extended</option>
                                </select>
                            }
                        </td>
                        <td dataMaxed="@(alreadyMaxed.ToString())">
                            @if (!alreadyMaxed) {
                                <span class="blue-text" id="@ship.Key-number-needed-asc-@index" 
                                    data-short="@shortsToMax" data-standard="@standardsToMax" data-extended="@extendedsToMax">
                                    @shortsToMax
                                </span>
                            }
                        </td>
                        <td dataMaxed="@(alreadyMaxed.ToString())">
                            @if (!alreadyMaxed) {
                                <span class="blue-text" id="@ship.Key-time-needed-asc-@index" 
                                    data-short="@shortsTimeMax" data-standard="@standardsTimeMax" data-extended="@extendedsTimeMax"
                                      dt-short="@Model.Backup.MinutesToString(shortsTimeMax)" dt-standard="@Model.Backup.MinutesToString(standardsTimeMax)" dt-extended="@Model.Backup.MinutesToString(extendedsTimeMax)">
                                    @Model.Backup.MinutesToString(shortsTimeMax)
                                </span>
                            }
                        </td>
                    </tr>
                }
                <tr>
                    <td colspan="3"><span>Total time (as configured):</span></td>
                    <td><span id="total-asc-time-@index"></span></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
