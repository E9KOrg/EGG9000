<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function toggleShipButton(element){
        if (element.textContent == "•••") {
            element.textContent = "⟵";
            element.title = "Hide Extras";
        } else{
            element.textContent = "•••";
            element.title = "Show Extras";
        }

        var indexMatches = element.id.match(/\d/g);
        if(!indexMatches) return;

        var [rIndex, sIndex] = indexMatches;

        var capacityEl = document.getElementById(`capacity-div-${rIndex}-${sIndex}`);
        if (capacityEl != null) capacityEl.classList.toggle("hidden-ship-element");

        var fuelEl = document.getElementById(`fueling-div-${rIndex}-${sIndex}`);
        if (fuelEl != null) fuelEl.classList.toggle("hidden-ship-element");

        var dubCapEl = document.getElementById(`double-cap-badge-${rIndex}-${sIndex}`);
        if(dubCapEl != null) dubCapEl.classList.toggle("hidden-ship-element");

        var targetingEl = document.getElementById(`targeting-div-${rIndex}-${sIndex}`);
        if(targetingEl != null) targetingEl.classList.toggle("hidden-ship-element");
    }
</script>

<div id="shipsDiv-@index" class="ship-container">
    @{
        var shipIndex = 0;
        //These values control the size of ship images & circles
        var baseSize = 60;
        var strokeWidth = 3;
        // -- Calculated values --
        var radius = baseSize - (2 * strokeWidth);
        var circumfrence = radius * 2 * Math.PI;
        var svgSize = baseSize * 2;
        var shipImageSize = baseSize * 1.9;
        var imageOffsets = baseSize / 2 + ((baseSize - shipImageSize) / 2);
    }
    @foreach (var mission in iterableMissions ?? new List<SpaceMission>()) {
        var returns = DateTimeOffset.FromUnixTimeSeconds((long)mission.StartTime + (long)mission.DurationSeconds);
        var epochReturns = (long)(returns.ToUnixTimeSeconds());
        var epochCurrent = (long)(DateTimeOffset.Now.ToUnixTimeSeconds());
        var epochStarted = (long)(DateTimeOffset.FromUnixTimeSeconds((long)mission.StartTime).ToUnixTimeSeconds());
        var shipEmojiLink = getShipEmoji(mission.Ship);
        var capacityModifier = (int)(mission.Capacity / Model.Backup.GetNominalCapacity(mission));

        var initialPercentDone = mission.Status == Status.Fueling ? 0 : 100 - ((((double)(epochReturns - epochCurrent) / (double)(epochReturns - epochStarted)) * 100));
        var initialOffset = circumfrence - initialPercentDone / 100 * circumfrence;
        var initialAntiOffset = circumfrence - initialOffset;

        //The sole purpose of this is to hold information for DOM manipulation later :^)
        <span style="display: none; opacity: 0;" id="data-ship-@index-@shipIndex" data-vals="@circumfrence,@((mission.Status == Status.Fueling).ToString())">You found an easter egg ... Feel free to reach out to Daveed, he'll get a chuckle from that.</span>

        <div id="ship-card-@index-@shipIndex" class="ship-item card ship-card">
            <button id="ship-toggle-button-@index-@shipIndex" class="ship-toggle-button" onclick="toggleShipButton(this)" title="Hide Extras">⟵</button>
            <h4 class="card-header">
                @if (shipEmojiLink != "") {
                    <svg width="@svgSize" height="@svgSize" xmlns="http://www.w3.org/2000/svg">
                        <circle class="ship-progress-ring tooltip-custom" id="ship-ring-@index-@shipIndex" stroke-width="@strokeWidth" stroke="@durationColor(mission.Duration)" fill="transparent" r="@radius" cx="@baseSize" cy="@baseSize"
                        style="stroke-dasharray: @circumfrence @circumfrence; stroke-dashoffset: @initialOffset;"/>
                        <circle class="ship-progress-anti-ring" id="ship-antiring-@index-@shipIndex" stroke-width="@strokeWidth" stroke="gray" fill="transparent" r="@radius" cx="@baseSize" cy="@baseSize"
                        style="stroke-dasharray: @circumfrence @circumfrence; stroke-dashoffset: @initialAntiOffset;" />
                        <image alt="@mission.Ship.ToString().Replace("_", " ")" x="@imageOffsets" y="@imageOffsets" width="@shipImageSize" height="@shipImageSize" xlink:href="@shipEmojiLink" />
                    </svg><br/>
                }
                <span style="font-size: 1.1rem; color: @durationColor(mission.Duration);">@mission.Duration.ToString().Replace("Epic", "Extended").Replace("Long","Standard")</span><br>
                @mission.Ship.ToString().Replace("_", " ")<br>
                <span id="ship-progress-stars-@index-@shipIndex" style="font-size: 1.2rem;">
                    @for (var i = 0; i < MissionHelpers.MaxShipLevels[mission.Ship]; i++) {
                        <span class="ShipCardStar @((i < mission.Stars) ? "GoldenStar" : "GrayStar")">★</span>
                    }
                </span>
            </h4>

            <div class="card-body" style="height: 150%">
                <span class="status-span" id="status-span-@index-@shipIndex">@mission.Status</span>
                @switch (mission.Status) {
                    case Status.Fueling:
                        <div id="fueling-div-@index-@shipIndex">
                            @{
                                var fuelTargets = Ei.MissionInfo.GetFuelTargets(mission.Ship, mission.Duration);
                                var needsFuel = mission == null || fuelTargets.Any(ft => ft.Value > (mission.Fuels.FirstOrDefault(f => f.Egg == ft.Key)?.Amount ?? 0));
                                        @if (needsFuel)
                                {
                                            <div style="color:darkred">❗Needs Fuel</div>
                                }
                                foreach (var fuel in mission.Fuels)
                                {
                                    var eggEmojiUrl = $"{EggIncEggs.GetEggById(fuel.Egg)?.Image}";
                                    var target = fuelTargets[fuel.Egg];
                                    var percent = fuel.Amount / target * 100;
                                    var eggName = string.Join(" ", Regex.Split(Enum.GetName(typeof(Ei.Egg), fuel.Egg).ToString(), @"(?=\p{Lu})"));
                                    if (eggName.StartsWith(" ")) eggName = eggName.Substring(1);
                                    var progressClass = $"{eggName.Replace(" ", "-").ToLower()}-progress-bar";
                                    var barWidth = (80 * (percent / 100)) + "px";
                                            <div style="width: 60%; margin-top: 2.5px; margin-bottom: 2.5px;">
                                                <span style="width: 150%; display: flex; align-items: center; height: 35px;">
                                                    <img style="height: 20px; width: 20px;" src="@(eggEmojiUrl)" title="@(eggName)" />&nbsp;
                                                    <span style="width: @barWidth; height: 15px;" class="fuel-progress-bar tooltip-custom @progressClass"></span>
                                                    @if (percent.ToString("N0") == "100"){
                                                        <span class="fuel-progress-text">100% - @fuelAmountsToText(target)</span>
                                            } else{
                                                        <span class="fuel-progress-text">@(percent.ToString("N0"))% - @fuelAmountsToText(fuel.Amount) / @fuelAmountsToText(target)</span>
                                            }
                                                </span>
                                            </div>
                                }
                            }
                        </div>
                        break;
                    case Status.Exploring:
                    case Status.Returned:
                        <div>
                            <span class="tooltip-custom" id="ttr-ship-@index-@shipIndex">
                                <span id="timetext-@index-@shipIndex">
                                    @((returns < DateTimeOffset.Now ? "Returned" : "Returns in")) <span style="font-weight: bold;" id="ship-return-m-@index-@shipIndex" data-duration="@mission.Duration" percent-done="" timedatastarted="@mission.StartTime" timedataends="@epochReturns">formatEpochToTime(epochReturns, false)</span> @((returns < DateTimeOffset.Now ? "ago" : ""))
                                </span>
                                <span id="ship-return-tt-@index-@shipIndex" class="tooltiptext-custom speech-bubble">
                                    Placeholder... Why are you looking here?
                                </span>
                            </span>
                        </div>
                        break;
                }
                <div id="capacity-div-@index-@shipIndex" style="flex: 1">Capacity: @((mission.Capacity))</div>
                <!-- Only quintillion (4) and above can be targeted ships-->
                @if (((int)mission?.Ship >= 4) && mission?.Targeting != null) {
                    @switch (mission?.Targeting) {
                        case Ei.ArtifactSpec.Types.Name.Unknown:
                            break;
                        default:
                            var targetInfo = ArtifactHelpers.GetTargetInfo(mission.Targeting);
                            if(targetInfo is not null && targetInfo?.Name != ""){
                                if(targetInfo.EmojiURL != ""){
                                    <div id="targeting-div-@index-@shipIndex" style="flex: 1">Targeting: @(targetInfo.Name) <img title="@(targetInfo.Name)" style="max-height: 25px;" src="@(targetInfo.EmojiURL)" /></div>
                                } else {
                                    <div id="targeting-div-@index-@shipIndex" style="flex: 1">Targeting: @(targetInfo.Name)</div>
                                }
                            }
                            break;
                    }
                }

                <!-- Double cap span, will be displayed conditionally-->
                @if(capacityModifier > 1 && mission.Status != Status.Fueling){
                    <span id="double-cap-badge-@index-@shipIndex" class="double-cap-span" style="flex: 1">
                        <img src="https://eggincassets.tcl.sh/64/egginc/icon_afx_chest_2.png" style="height: 30px" />
                        <span class="tooltip-custom" style="font-weight: bold">@(capacityModifier)x Capacity
                            <span style="font-weight: normal;" class="tooltiptext-custom speech-bubble">This ship was launched during a<br /><span style="color: rgb(139, 14, 158)">@(capacityModifier)x Capacity Event</span> and will return with<br />more artifacts than normal.</span>
                        </span>
                    </span>
                }
            </div>
        </div>
        shipIndex++;
    }
</div>

<div id="shipInfoContainer-@index" class="asc-info-container" style="display: flex; margin-top: 15px;">
    <div id="ship-level-container-@index" style="margin-left: 10px; width:60%; display: block;">
        <table id="ship-level-table" class="table card table-sm" style="width: 100%; table-layout: auto; display: table;">
            <thead>
                <tr>
                    <th style="text-align: center;">Ship</th>
                    <th>Stars</th>
                    <th>Next Level</th>
                    <th>Max Level</th>
                    <th>Launches</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ship in MissionHelpers.MaxShipLevels) {
                    var currentStars = Model.Backup.GetShipLevel(ship.Key);
                    var shipEmojiLink = getShipEmoji(ship.Key);
                    <tr id="@ship.Key-overall-row" style="height: 38px;">
                        <td align="center">
                            @if (shipEmojiLink != "") {
                                <img src="@((shipEmojiLink))" title="@MissionHelpers.GetProperShipName(ship.Key)" style="max-height:20px;">
                            }
                        </td>
                        <td>
                            @for (var i = 0; i < ship.Value; i++) {
                                if (i < currentStars){
                                    <span class="Star GoldenStar">★</span>
                                } else {
                                    <span class="Star GrayStar">★</span>
                                }
                            }
                        </td>
                        <td>
                            @if (Model.Backup.GetShipProgressTotal(ship.Key) != 1) {
                                <span class="tooltip-custom">
                                    @Model.Backup.GetShipProgressNextLevel(ship.Key).ToString("P0")
                                    <span class="tooltiptext-custom speech-bubble">
                                        @{
                                            var shipsToNext = Model.Backup.LaunchShipsToNext(ship.Key);
                                            var shortsToNext = shipsToNext.ContainsKey(DurationType.Short) ? shipsToNext[DurationType.Short] : 0;
                                            var standardsToNext = shipsToNext.ContainsKey(DurationType.Long) ? shipsToNext[DurationType.Long] : 0;
                                            var extendedsToNext = shipsToNext.ContainsKey(DurationType.Epic) ? shipsToNext[DurationType.Epic] : 0;

                                            var shortsTimeNext = Model.Backup.GetShipTime(ship.Key, DurationType.Short, shortsToNext);
                                            var standardsTimeNext = Model.Backup.GetShipTime(ship.Key, DurationType.Long, standardsToNext);
                                            var extendedsTimeNext = Model.Backup.GetShipTime(ship.Key, DurationType.Epic, extendedsToNext);
                                        }
                                        <span id="@ship.Key-short-nextlvl" timeval="@shortsTimeNext" intval="@shortsToNext" class="blue-text">@shortsToNext @properCaseAndSuffix("Short", shortsToNext)</span><span class="gray-text-half-margin">or</span>
                                        <span id="@ship.Key-standard-nextlvl" timeval="@standardsTimeNext" intval="@standardsToNext" class="purple-text">@standardsToNext @properCaseAndSuffix("Standard", standardsToNext)</span><span class="gray-text-half-margin">or</span>
                                        <span id="@ship.Key-extended-nextlvl" timeval="@extendedsTimeNext" intval="@extendedsToNext" class="orange-text">@extendedsToNext @properCaseAndSuffix("Extended", extendedsToNext)</span>
