                        </td>
                    </tr>
                }
            </tbody>
        </table>
        <span id="do-tt-@index" class="tooltip-text">ℹ️<i>Press CTRL to toggle showing times for ship launches in tooltips.</i></span>
        <button class="btn-primary tooltip-text" id="mo-tt-@index" style="margin-bottom: 10px;" onclick="toggleShipTimes()"><span>Toggle showing times in tooltips.</span></button>
