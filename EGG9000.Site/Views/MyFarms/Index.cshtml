@model MyFarmsModel
@using Discord.WebSocket
@using EGG9000.Common.Helpers
@using EGG9000.Common.JsonData
@using Microsoft.AspNetCore.Html
@using static EGG9000.Site.Controllers.MyFarmsController
@using EGG9000.Common.JsonData.EIEpicResearch;
@inject DiscordSocketClient discordClient
@{
    ViewData["Title"] = "Index";

    List<Contract> contracts = Model.Contracts;

    List<UserSnapShot> snapshots = Model.SnapShots;

    List<UserCoopXref> unjoinedCoops = Model.UnjoinedCoops.ToList();

    List<EpicResearchItem> epicResearchConfig = Model.EpicResearchConfig;

    Dictionary<string, List<EGG9000.Common.Database.Entities.Contract>> uncompletePEs = Model.UncompletedPEContracts;

    List<(string EggIncId, Ei.MyContracts MyContracts)> scoring = Model.Scoring;
    Guild dbguild = Model.DBGuild;

    var isAdmin = User.IsInRole("Admin") || User.IsInRole("GuildAdmin");
    // Read/staff tier - gates display-only context when viewing another user's farms (titles, status
    // badges, extra columns). All write controls (remove merit/demerit) are gated on isAdmin instead, so
    // the read-only GuildReadOnlyAdmin (CT) tier is safe to include here.
    var isLesserAdmin = isAdmin || User.IsInRole("GuildLesserAdmin") || User.IsInRole("GuildReadOnlyAdmin");
    var isSelf = Model.IsSelf;

    var emojiReplace = new Regex(@"<:[^:]+:(\d+)>");

    string emojiDelegage(Match match) {
        return $"<img src='https://cdn.discordapp.com/emojis/{match.Groups[1]}.png?size=22' />";
    };

    string accountName(string eggIncId){
        var account = Model.User.EggIncAccounts.FirstOrDefault(a => a.Id == eggIncId);
        if (account is null) return eggIncId;
        return account.Backup?.UserName ?? eggIncId;
    }

    var inDB = Model.User.DiscordId > 0;

}
<style>
    .card-header img {
        height: 50px;
        margin: -31px -8px -25px -22px;
    }

    .card {
        vertical-align: top;
    }

    .tight-emojis {
        letter-spacing: -0.5em;
    }

    .nobreak span {
        white-space: nowrap;
    }

    .tab-pane .container {
        padding: 0px;
    }

    .Expired td {
        opacity: 60%;
    }

    .tooltip-custom {
        position: relative;
        display: inline-block;
    }

        .tooltip-custom:hover .tooltiptext-custom {
            display: inline-block;
            z-index: 3;
            position: absolute;
            bottom: 25px;
            left: 50%;
            transform: translateX(-50%); /* Center the tooltip */
        }

    .tooltiptext-custom {
        display: none;
        border: 1px solid #ccc;
        padding: 10px;
        border-radius: 4px;
        white-space: nowrap;
        text-align: center; /* Center the text within the tooltip */
        position: absolute;
    }

        .tooltiptext-custom .bootstrap-dark {
            background-color: rgba(33, 37, 41, 0.95);
        }

        .tooltiptext-custom .bootstrap {
            background-color: rgba(130, 135, 140, 0.95);
        }

    .bootstrap-dark .speech-bubble {
        background-color: rgba(33, 37, 41, 0.95);
    }

    .bootstrap .speech-bubble {
        background-color: rgba(130, 135, 140, 0.95);
    }

    .speech-bubble {
        position: relative;
        padding: 10px;
        margin: 10px auto; /* Center the bubble horizontally */
        border-radius: 5px; /* Rounded corners for the bubble */
    }

        /* Create the triangle */
        .speech-bubble :after {
            content: "";
            position: absolute;
            top: 100%;
            left: 50%;
            margin-left: -15px; /* Half of the triangle's width */
            border-width: 15px;
            border-style: solid;
            border-color: #ccc transparent transparent transparent;
        }
</style>

<script>
    function copyIdToClipboard(id, notifId) {
        // If the passed parameter is an HTML element, get its inner text
        const content = (typeof id === "object") ? id.innerText : id.toString();
        navigator.clipboard.writeText(content);

        if (notifId) {
            // Show the notification
            var notification = document.getElementById(notifId);
            notification.style.display = "block";
            notification.style.opacity = "1";

            // Hide the notification after 2 seconds (adjust the duration as needed)
            setTimeout(function () {
                notification.style.opacity = "0";
            }, 2000);
        }
    }

    function formatEpochToTime(epochSeconds, full) {
        // Calculate the difference between the epoch time and the current time in seconds
        var timeDifference = epochSeconds - Math.floor(Date.now() / 1000);

        if (timeDifference < 0) {
            // If the time is in the past, invert to assume counting up.
            timeDifference *= -1;
        }

        var months = Math.floor(timeDifference / 2592000); // 2592000 seconds in a month (30 days)
        var weeks = Math.floor((timeDifference % 2592000) / 604800); // 604800 seconds in a week
        var days = Math.floor(((timeDifference % 2592000) % 604800) / 86400); // 86400 seconds in a day
        var hours = Math.floor(((timeDifference % 2592000) % 86400) / 3600); // 3600 seconds in an hour
        var minutes = Math.floor(((timeDifference % 2592000) % 3600) / 60); // 60 seconds in a minute
        var seconds = timeDifference % 60; // 60 seconds in a minute

        // Format the result as "XwXdXhXmXs"
        var result = (
            "" +
            (months > 0 ? `${months}M` : "") +
            (weeks > 0 ? `${weeks}w` : "") +
            (days > 0 ? `${days}d` : "") +
            (hours > 0 && (months == 0 && weeks == 0 || full) ? `${hours}h` : "") +
            ((minutes > 0 && (months == 0 && weeks == 0 && days == 0 && hours < 10 || full)) ? `${minutes}m` : "") +
            ((seconds > 0 && ((minutes < 10 && hours == 0 && days == 0 && weeks == 0 && months == 0) || full)) ? `${seconds}s` : "")
        ) ?? "0s";
        if (result == "") result = "0s";

        return result;
    }
</script>

@if ((isAdmin || isLesserAdmin) && !isSelf) {
    <h1>@Model.User.DiscordUsername's Farms</h1>
} else {
    <h1>My Farms</h1>
}

@if (unjoinedCoops.Any()) {
    <div class="alert alert-danger">
        @if ((isAdmin || isLesserAdmin) && !isSelf){
            <span>@Model.User.DiscordUsername has not joined the following coops they've been assigned.</span>
        } else{
            <span>Pssst... It looks like you haven't joined the following coops that you've been assigned!</span>
        }
        <div class="font-weight-bold" style="margin-top:10px;">
            @foreach (var xref in unjoinedCoops) {
                <div>
                    <img style="max-height: 30px;" src="@(EggIncStatics.GetEggByContract(xref.Coop.Contract, Model.CustomEggs).image)" />
                    @if(Model.User.EggIncAccounts.Count > 1) {
                        <span>@xref.Coop.Contract.Name - @xref.Coop.Name (@accountName(xref.EggIncId))</span>
                    } else {
                        <span>@xref.Coop.Contract.Name - @xref.Coop.Name</span>
                    }
                    @if(xref.Coop.ThreadID != 0)
                    {
                        <a href="discord://discordapp.com/channels/@xref.Coop.OverflowGuildId/@xref.Coop.ThreadID/">
                            <img src="/images/discordicon.png" style="max-height: 1em;" />
                        </a>
                    }
                </div>
            }
        </div>
    </div>
}

@if(Model.User.DMSBlocked){
    <div class="alert alert-danger">
        @if ((isAdmin || isLesserAdmin) && !isSelf){
            <span><b>@Model.User.DiscordUsername has blocked DMs from EGG9000.</b></span>
        } else{
            <span><b>It looks like you've blocked DMs from EGG9000</b>.<br />This can either be due to Server Privacy settings, or directly blocking the bot.<br />This may lead to missed communications - please resolve this.</span>
            <div class="font-weight-bold" style="margin-top:10px;">
                <a href="https://support.discord.com/hc/en-us/articles/217916488-Blocking-Privacy-Settings-">
                    <img style="max-height: 30px" src="https://assets-global.website-files.com/6257adef93867e50d84d30e2/636e0a69f118df70ad7828d4_icon_clyde_blurple_RGB.svg"/> 
                    See this Discord support article for help fixing this issue.
                </a>
            </div>
        }
    </div>
}

<div>
    @if (isLesserAdmin || isAdmin) {
        if (Model.User.TempDisabled) {
            <span style="color: #FF0000">❗User is disabled</span>
        }
    }
</div>

<div style="padding-bottom: 10px;">
    <span style="margin-right:10px;" title="Click to copy" id="discord-name-copy-button" onclick="copyIdToClipboard('@(Model.User.DiscordUsername?.Split(" (")[0] ?? "")', 'copy-notification-discord-name')"><b><u>Discord Name</u></b>: @Model.User.DiscordUsername</span>
    <div class="copy-notification" id="copy-notification-discord-name">Discord username copied!</div>
    <span style="margin:5px;" title="Click to copy" id="discord-id-copy-button" onclick="copyIdToClipboard('@Model.User.DiscordId', 'copy-notification-discord')"><b><u>Discord ID</u></b>: @Model.User.DiscordId</span>
    <div class="copy-notification" id="copy-notification-discord">Discord ID copied!</div>
    @if (Model.User.GuildId == 0) {
        <span style="margin:5px; color: #FFAA33;">⚠️ Not currently a member of a Discord server, might need to run /moveserver if you are supposed to be</span>
    } else {
        <span style="margin:5px;"><b><u>Member of</u></b>: @(discordClient.Guilds.FirstOrDefault(x => x.Id == Model.User.GuildId)?.Name ?? "unknown")</span>
    }
</div>


@if (Model.User.EggIncAccounts.Count > 1) {
    <ul class="nav nav-tabs" role="tablist">
        @for (var index = 0; index < Model.User.EggIncAccounts.Count; index++) {
            var account = Model.User.EggIncAccounts[index];
            <li class="nav-item">
                <a class="nav-link @(index == 0 ? "active" : "")" id="tab@(account.Id)" data-toggle="tab" href="#user@(index)" role="tab" aria-selected="@(index == 0)">
                    @account.Backup.UserName
                    <img src="@PlayerGradeDetails.GetImage(account.GetGrade())" style="max-height: 23px;" />
                    @if (account.Backup.PermitLevel == 0) {
                        <img src="https://cdn.discordapp.com/emojis/755734059761795173.png?v=1" style="max-height: 23px;" />
                    } else {
                        <img src="https://cdn.discordapp.com/emojis/724392625276452955.png?v=1" style="max-height: 23px;" />
                    }
                </a>
            </li>
        }
    </ul>
}

<div class="tab-content">
    @for (var index = 0; index < Model.User.EggIncAccounts.Count; index++) {
        var account = Model.User.EggIncAccounts[index];
        var backup = account.Backup;
        <div class="tab-pane @(index == 0 ? "show active" : "")" id="user@(index)" role="tabpanel">
            <div style="padding-bottom: 10px;" class="nobreak">
                @if (Model.User.EggIncAccounts.Count == 1) {
                    @:<span style="margin-right:10px;"><b><u>In-Game Name</u></b>: @backup.UserName</span>
                    <img src="@PlayerGradeDetails.GetImage(account.GetGrade())" style="max-height: 23px;" />
                    @if (backup.PermitLevel == 0) {
                        <img src="https://cdn.discordapp.com/emojis/755734059761795173.png?v=1" style="max-height: 23px;" />
                    } else {
                        <img src="https://cdn.discordapp.com/emojis/724392625276452955.png?v=1" style="max-height: 23px;" />
                    }
                }
                <span style="margin-right:10px;" onclick="copyIdToClipboard('@backup.EggIncId', 'copy-notification-eid-@index')" title="Click to copy"><b><u>EggIncId</u></b>: @backup.EggIncId</span>
                <div class="copy-notification" id="copy-notification-eid-@index">EID copied!</div>
                <span style="margin-right:10px;">
                    <b><u>Last Backup</u></b>: 
                    <span class="tooltip-custom">
                        <span id="last-backup-disp-@index" data-lb="@backup.LastBackupTime"></span>
                        <script>document.getElementById('last-backup-disp-@index').textContent = formatEpochToTime(@backup.LastBackupTime, false);</script>
                        <span id="last-backup-tooltip-@index" class="tooltiptext-custom speech-bubble"></span>
                    </span>
                </span>
                @if (backup.MaxEggReached < Ei.Egg.Enlightenment) {
                    <span style="margin-right:10px;"><b><u>Highest Egg</u></b>: @backup.MaxEggReached</span>
                }
                <br>
                @if (dbguild is not null && !dbguild.DisableBG) {
                    if (account.Group == 0) {
                        <span style="margin-right:10px; color: #FFAA33"><b>⚠️Boarding Group Not Set</b></span>
                    } else {
                        <span style="margin-right:10px;"><b><u>Boarding Group @account.Group</u></b></span>
                    }
                    if (account.HasActiveSubscription()) {
                        if (account.UltraGroup == 0) {
                            <span style="margin-right:10px; color: #FFAA33"><b>⚠️Ultra Boarding Group Not Set</b></span>
                        } else {
                            <span style="margin-right:10px;"><b><u>Ultra Boarding Group @account.UltraGroup</u></b></span>
                        }
                    }
                    if(!String.IsNullOrWhiteSpace(account.Guild)) {
                        <span style="margin-right:10px;"><b><u>Guild</u></b>: @account.Guild</span>
                    }
                }
                @if (account.OnBreakUntil > DateTimeOffset.Now) {
                    <span style="margin-right:10px;" title="Date/Time displayed in local time"><b><u>On Break until</u></b>: @account.OnBreakUntil.ToLocalTime().ToString("yyyy-MM-dd h:mm:ss tt")</span>
                }
                @if ((account.AutoRegisterRewards?.Count ?? 0) > 0) {
                    <span style="margin-right:10px;"><b><u>Filter</u></b>: @string.Join(",", account.AutoRegisterRewards)</span>
                } else {
                    <span style="margin-right:10px;"><b><u>Filter</u></b>: All</span>
                }
                @if ((account.LeggacyAutoRegisterRewards?.Count ?? 0) > 0) {
                    <span style="margin-right:10px;"><b><u>Leggacy Filter</u></b>: @string.Join(",", account.LeggacyAutoRegisterRewards)</span>
                }
                <span style="margin-right:10px;">
                    <b><u>Redo Leggacies</u></b>:
                    @if (account.RedoLeggacySelection == RedoLeggacyOption.YesAll) {
                        @string.Join("", "Yes (All)")
                    } else if(account.RedoLeggacySelection == RedoLeggacyOption.YesNoUltra) {
                        @string.Join("", "Yes (No ultra-redos)")
                    } 
                    else if (account.RedoLeggacySelection == RedoLeggacyOption.YesThreshold) {
                        @string.Join("", $"Yes (Under {account.RedoScoreThreshold} CS)")
                    } else if(account.RedoLeggacySelection == RedoLeggacyOption.YesOtherAccountMatch) {
                        @string.Join("", "Yes (If other account matches)")
                    } else {
                        @string.Join("", "No")
                    }
                </span>
                @if(account?.LatestRunningScore != 0){
                    <br /><span><b><u>Latest Running Score</u></b>: @account.LatestRunningScore.ToString("G3")</span>
                }
            </div>

            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" data-toggle="tab" href="#contracthistory@(index)" role="tab" aria-selected="true">Contract History</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#shipsfarms@(index)" role="tab" aria-selected="false">Ships & Farms</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#epicresearch@(index)" role="tab" aria-selected="false">Epic Research</a>
                </li>
                @if (inDB) {
                    var tabName = isAdmin ? $"Merits ({Model.Merits.Count}) & Demerits ({Model.Demerits.Count})" : $"Merits & Demerits";
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#merits@(index)" role="tab" aria-selected="false">@tabName</a>
                    </li>
                    @if (snapshots != null) {
                        <li class="nav-item">
                            <a class="nav-link" data-toggle="tab" href="#ebhistory@(index)" role="tab" aria-selected="false">EB Stats</a>
                        </li>
                    }
                }
                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#artifactcombos@(index)" role="tab" aria-selected="false">Artifact Combos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#externaltools@(index)" role="tab" aria-selected="false">External Tools</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#earningsboostcalc@(index)" role="tab" aria-selected="false">Earnings Boost Calc</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#colleggtibles@(index)" role="tab" aria-selected="false">Colleggtibles</a>
                </li>
                <!--<li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#inventoryview(index)" role="tab" aria-selected="false">Inventory View</a>
                </li>-->
            </ul>

            <div class="tab-content">
                <div class="tab-pane" style="margin-top:20px" id="shipsfarms@(index)" role="tabpanel">
                    @{
                        await Html.RenderPartialAsync("-ShipsandFarms", (index, backup, Model.JoinedCoops, contracts, Model.CustomEggs));
                    }
                </div>

                 <div class="tab-pane" id="epicresearch@(index)" role="tabpanel">
                    @{
                        await Html.RenderPartialAsync("-EpicResearch", (epicResearchConfig, backup, account));
                    }
                </div>
                <div class="tab-pane" id="artifactcombos@(index)" role="tabpanel">
                    @{
                        await Html.RenderPartialAsync("-ArtifactCombos", (backup, contracts, Model.JoinedCoops, Model.User, Model.CustomEggs));
                    }
                </div>
                
                @if (inDB) {
                    <div class="tab-pane" id="merits@(index)" role="tabpanel">
                        <div class="container">
                            <div class="row">
                                <div class="col-sm">
                                    @{
                                        <div class="card" style="margin-top:20px">
                                            <table class="table table-striped">
                                                <caption style="caption-side: top; text-align: center; font-weight: bold;"><u>Merits</u></caption>
                                                @if (Model.Merits.Count > 0) {
                                                    <tbody>
                                                        <tr>
                                                            <th class="text-left">Date</th>
                                                            <th>Reason</th>
                                                            @if (isAdmin) {
                                                                <th></th>
                                                            }
                                                        </tr>
                                                    </tbody>
                                                    <tbody>
                                                        @foreach (var merit in Model.Merits) {
                                                            <tr>
                                                                <td style="white-space: nowrap">@merit.When.ToString("yyyy-MM-dd")</td>
                                                                <td> @Html.Raw(emojiReplace.Replace(merit.Reason, emojiDelegage))</td>
                                                                @if (isAdmin) {
                                                                    <td><a href="/myfarms/removemerit?id=@merit.Id" title="Remove Merit">X</a></td>
                                                                }
                                                            </tr>
                                                        }
                                                    </tbody>
                                                } else {
                                                    <tr style="padding: 20px; margin-top:20px; text-align: center">
                                                        <td>No merits for user.</td>
                                                    </tr>
                                                }
                                            </table>
                                        </div>
                                    }
                                </div>
                                <div class="col-sm">
                                    @{
                                        List<Demerit> demerits = Model.Demerits;
                                        <div class="card" style="margin-top:20px">
                                            <table class="table table-striped">
                                                <caption style="caption-side: top; text-align: center; font-weight: bold;">Demerits</caption>
                                                <thead>
                                                    <tr>
                                                        <th class="text-left">Date</th>
                                                        <th>Reason</th>
                                                        @if (isAdmin) {
                                                            <th></th>
                                                        }
                                                    </tr>
                                                </thead>
                                                @if (Model.Demerits.Count > 0) {
                                                    <tbody>
                                                        @foreach (var demerit in demerits.OrderByDescending(x => x.When)) {
                                                            <tr class="@(demerit.When < DateTimeOffset.Now.AddMonths(-1) && !demerit.Permanent ? "Expired" : "")">
                                                                <td style="white-space: nowrap">@demerit.When.ToString("yyyy-MM-dd")</td>
                                                                <td> @Html.Raw(emojiReplace.Replace(demerit.Reason, emojiDelegage))</td>
                                                                @if (isAdmin) {
                                                                    <td><a href="/myfarms/removedemerit?id=@demerit.Id" title="Remove Demerit">X</a></td>
                                                                }
                                                            </tr>
                                                        }
                                                    </tbody>
                                                } else {
                                                    <tr style="padding: 20px; margin-top:20px; text-align: center">
                                                        <td>No demerits for user.</td>
                                                    </tr>
                                                }
                                            </table>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    @if (snapshots != null) {
                        <div class="tab-pane" id="ebhistory@(index)" role="tabpanel">
                            @{
                                await Html.RenderPartialAsync("-EBHistory", (backup, snapshots, isAdmin, uncompletePEs, contracts, Model.SeasonPEByEggIncId.GetValueOrDefault(backup.EggIncId, (Earned: 0, Max: 0)), Model.MissingSeasonalPEByEggIncId.GetValueOrDefault(backup.EggIncId, new List<EGG9000.Site.Controllers.MyFarmsController.MissingSeasonalPe>())));
                            }
                        </div>
                    }
                }
                <div class="tab-pane show active" id="contracthistory@(index)" role="tabpanel">
                    @{
                        Ei.MyContracts scores = scoring.Any(x => x.EggIncId == backup.EggIncId) ? scoring.First(x => x.EggIncId == backup.EggIncId).MyContracts : null;
                        await Html.RenderPartialAsync("-ContractHistory", (backup, isAdmin, contracts, Model.CustomEggs, Model.User, scores, index));
                    }
                </div>

                <div class="tab-pane" id="externaltools@(index)" role="tabpanel">
                    @{
                        await Html.RenderPartialAsync("-ExternalTools", (backup, Model.User));
                    }
                </div>

                <div class="tab-pane" id="earningsboostcalc@(index)" role="tabpanel">
                    @{
                        var newModel = new EarningsBoostCalculatorModel();
                        newModel.Backup = backup;
                        newModel.CustomEggs = Model.CustomEggs;
                        await Html.RenderPartialAsync("-EarningsBoostCalculator", (newModel));
                    }
                </div>
                <div class="tab-pane" id="colleggtibles@(index)" role="tabpanel">
                    @{
                        await Html.RenderPartialAsync("-Colleggtibles", (backup, Model.CustomEggs));
                    }
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>

        function formatEpochToLocalDateTime(epochSeconds) {
            // Convert the epoch time to milliseconds and create a Date object
            var date = new Date(epochSeconds * 1000);

            // Get date and time components
            var year = date.getFullYear();
            var month = String(date.getMonth() + 1).padStart(2, '0'); // Months are zero-based
            var day = String(date.getDate()).padStart(2, '0');
            var hours = String(date.getHours()).padStart(2, '0');
            var minutes = String(date.getMinutes()).padStart(2, '0');
            var seconds = String(date.getSeconds()).padStart(2, '0');

            // Format the result as "YYYY-MM-DD HH:mm:ss"
            var result = `${year}-${month}-${day} ${hours}:${minutes}:${seconds}`;
            return result;
        }

        function updateLastBackupTime() {
            var elements = document.querySelectorAll('[id^="last-backup-disp"]');
            elements.forEach(function (el) {
                var timeData = parseInt(el.getAttribute('data-lb'));
                el.textContent = formatEpochToTime(timeData, false);
                var index = el.id.replace('last-backup-disp-', '');

                var fullTime = formatEpochToTime(timeData, true);
                var localTime = formatEpochToLocalDateTime(timeData);
                var newInnerHTML = `${fullTime} ago <br><span style="color: grey;">(</span> ${localTime} <span style="color: grey;">)</span>`;

                document.getElementById('last-backup-tooltip-' + index).innerHTML = newInnerHTML;
            });
        }

        $(document).ready(() => {
            let url = location.href.replace(/\/$/, "");

            updateLastBackupTime();

            if (location.hash) {
                const hash = url.split("#");
                var backupNum = hash[1].slice(-1);
                if (backupNum != "0") {
                    $('a[href="#user' + backupNum + '"]').tab("show");
                }

                $('a[href="#' + hash[1] + '"]').tab("show");
                url = location.href.replace(/\/#/, "#");
                history.replaceState(null, null, url);
                setTimeout(() => {
                    $(window).scrollTop(0);
                }, 400);

            }

            $('a[data-toggle="tab"]').on("click", function () {
                let newUrl;
                const hash = $(this).attr("href");

                console.log(hash.substring(1, 5));
                if (hash.substring(1, 5) == "user")
                    return;
                newUrl = url.split("#")[0] + hash;
                history.replaceState(null, null, newUrl);
            });

            $("[id^='ArchivedFarmsSearch']").keyup(function () {
                var terms = $(this).val().split(" ");
                var showAll = $(this).val().trim().length == 0;
                var index = $(this).attr('id').replace("ArchivedFarmsSearch", "");
                $('#ArchivedFarmsTBody' + index + ' tr').each(function (index) {
                    var row = $(this);
                    var name = row.data("name");
                    var coop = row.data("coop");
                    var matches = 0;
                    $.each(terms, function (index, value) {
                        if (name.toUpperCase().indexOf(value.toUpperCase()) !== -1 || (coop != undefined && coop.toLowerCase().indexOf(value.toLowerCase()) !== -1)) {
                            matches++;
                        }
                    });
                    var show = showAll || matches == terms.length;
                    if (show) {
                        $(this).show();
                    } else {
                        $(this).hide();
                    }
                });
            });

            setInterval(updateLastBackupTime, 1000);
        });
    </script>
}