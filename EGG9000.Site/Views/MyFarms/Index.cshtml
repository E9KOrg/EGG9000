@model EGG9000.Common.Database.Entities.DBUser
@using Discord.WebSocket
@using EGG9000.Common.Helpers
@using Microsoft.AspNetCore.Html
@using static EGG9000.Common.Helpers.EpicResearchCalc
@inject DiscordSocketClient discordClient
@{
	ViewData["Title"] = "Index";

	List<Contract> contracts = ViewBag.Contracts ?? new List<Contract>();

	List<UserSnapShot> snapshots = ViewBag.Snapshots ?? new List<UserSnapShot>();

	List<UserCoopXref> userCoops = ViewBag.Coops ?? new List<UserCoopXref>();

	List<EpicResearchDetail> epicResearchConfig = ViewBag.EpicResearchConfig ?? new List<EpicResearchDetail>();

	@*Func<EggIncArtifactInstance, object> artifactTemplate = @<span>
		<span>@item.Artifact</span>
		@if(item.Additive) {
		<span>+@item.Value</span>
		} else if(item.Value < 2) {
		<span>@Math.Round((item.Value - 1) * 100)%</span>
		} else {
		<span>@(item.Value)x</span>
		}
		<span>@item.Boost</span>
		</span>;*@

	var isAdmin = User.IsInRole("Admin") || User.IsInRole("GuildAdmin");
	var isLesserAdmin = isAdmin || User.IsInRole("GuildLesserAdmin");
	List<Ei.Backup> rawBackups = ViewBag.RawBackups;


	var emojiReplace = new Regex(@"<:[^:]+:(\d+)>");

	string emojiDelegage(Match match) {
		return $"<img src='https://cdn.discordapp.com/emojis/{match.Groups[1]}.png?size=22' />";
	};
	List<Merit> merits = ViewBag.Merits;
	var inDB = Model.DiscordId > 0;
}
<style>
	.card-header img {
		height: 50px;
		margin: -31px -8px -25px -22px;
	}

	.card {
		vertical-align: top;
	}

	.tight-emojis {
		letter-spacing: -0.5em;
	}
</style>


@if (isAdmin) {
	<h1>@Model.DiscordUsername Farms</h1>
} else {
	<h1>My Farms</h1>
}

@if (userCoops.Any()) {
	@if (isAdmin) {
		<div class="alert alert-danger">
			@Model.DiscordUsername has not joined the following coops they've been assigned.
			<div class="font-weight-bold" style="margin-top:10px;">
				@foreach (var coop in userCoops) {
					<div><img style="max-height: 30px;" src="/images/Egg_@((int)coop.Coop.Contract.Details.Egg).png" />@coop.Coop.Contract.Name - @coop.Coop.Name</div>
				}
			</div>
		</div>
	} else {
		<div class="alert alert-danger">
			Pssst... It looks like you haven't joined the following coops that you've been assigned!
			<div class="font-weight-bold" style="margin-top:10px;">
				@foreach (var coop in userCoops) {
					<div>><img style="max-height: 30px;" src="/images/Egg_@((int)coop.Coop.Contract.Details.Egg).png" />@coop.Coop.Contract.Name - @coop.Coop.Name</div>
				}
			</div>
		</div>
	}
}

<div>

	<a asp-action="EarningsBoostCalculator">Earnings Boost Calculator </a>

	@if (isLesserAdmin) {
		if (Model.TempDisabled) {
			<span>User is disabled</span>
		}
	}
</div>




@if (Model.Backups.Count > 1) {
	<ul class="nav nav-tabs" role="tablist">
		@foreach (var backup in Model.Backups) {
			var index = Model.Backups.IndexOf(backup);
			<li class="nav-item">
				<a class="nav-link @(backup == Model.Backups.First() ? "active" : "")" id="tab@(backup.EggIncId)" data-toggle="tab" href="#user@(index)" role="tab" aria-selected="@(backup == Model.Backups.First())">
					@backup.UserName
					@switch(Model.GetGrade(backup.EggIncId)) {
						case Ei.Contract.Types.PlayerGrade.GradeAaa:
							<img src="https://cdn.discordapp.com/emojis/1102985471862247426.png?v=1" style="max-height: 30px;" />
							break;
						case Ei.Contract.Types.PlayerGrade.GradeAa:
							<img src="https://cdn.discordapp.com/emojis/1102985434562297989.png?v=1" style="max-height: 30px;" />
							break;
						case Ei.Contract.Types.PlayerGrade.GradeA:
							<img src="https://cdn.discordapp.com/emojis/1102985380845867068.png?v=1" style="max-height: 30px;" />
							break;
						case Ei.Contract.Types.PlayerGrade.GradeB:
							<img src="https://cdn.discordapp.com/emojis/1102985335920668742.png?v=1" style="max-height: 30px;" />
							break;
						case Ei.Contract.Types.PlayerGrade.GradeC:
							<img src="https://cdn.discordapp.com/emojis/1102984452935794799.png?v=1" style="max-height: 30px;" />
							break;
					}
				</a>
			</li>
		}
	</ul>
} else {
	@switch(Model.GetGrade(Model.Backups.First().EggIncId)) {
		case Ei.Contract.Types.PlayerGrade.GradeAaa:
			<img src="https://cdn.discordapp.com/emojis/1102985471862247426.png?v=1" style="max-height: 30px;" />
			break;
		case Ei.Contract.Types.PlayerGrade.GradeAa:
			<img src="https://cdn.discordapp.com/emojis/1102985434562297989.png?v=1" style="max-height: 30px;" />
			break;
		case Ei.Contract.Types.PlayerGrade.GradeA:
			<img src="https://cdn.discordapp.com/emojis/1102985380845867068.png?v=1" style="max-height: 30px;" />
			break;
		case Ei.Contract.Types.PlayerGrade.GradeB:
			<img src="https://cdn.discordapp.com/emojis/1102985335920668742.png?v=1" style="max-height: 30px;" />
			break;
		case Ei.Contract.Types.PlayerGrade.GradeC:
			<img src="https://cdn.discordapp.com/emojis/1102984452935794799.png?v=1" style="max-height: 30px;" />
			break;
	}
}
<div class="tab-content">
	@foreach (var account in Model.EggIncAccounts) {
		var backup = Model.Backups.First(x => x.EggIncId == account.Id);
		var index = Model.Backups.IndexOf(backup);
		var rawBackup = rawBackups.First(x => x.EiUserId == backup.EggIncId);
		<div class="tab-pane @(backup == Model.Backups.First() ? "show active" : "")" id="user@(index)" role="tabpanel">
			<div style="padding-bottom: 10px;">
				@if (backup.PermitLevel == 0) {
					<img src="https://cdn.discordapp.com/emojis/755734059761795173.png?v=1" style="max-height: 30px;" />
				} else {
					<img src="https://cdn.discordapp.com/emojis/724392625276452955.png?v=1" style="max-height: 30px;" />
				}
				[<span>EggIncId: @backup.EggIncId</span>]
				@if (Model.Backups.Count == 1) {
					@:[<span>In-Game Name: @backup.UserName</span>]
				}
				[<span>Last Backup: @((DateTimeOffset.Now - DateTimeOffset.FromUnixTimeSeconds(backup.LastBackupTime)).Humanize())</span>]
				[@if (Model.GuildId == 0) {
					<span>Not currently a member of a Discord server, might need to run /moveserver if you are supposed to be</span>
				} else {
					<span>Member of discord server: @(discordClient.Guilds.FirstOrDefault(x => x.Id == Model.GuildId)?.Name ?? "unknown")</span>
				}]
				[BG @account.Group]
				@if(account.OnBreakUntil > DateTimeOffset.Now) {
					<span>[OnBreak @account.OnBreakUntil.ToString()]</span>
				}
				@if (account.AutoRegisterRewards.Count > 0)
				{
					<span>[Filter @string.Join(",", account.AutoRegisterRewards)]</span>
				} else {
					<span>[Filter All]</span>
				}
			</div>

			<ul class="nav nav-tabs" role="tablist">
				<li class="nav-item">
					<a class="nav-link active" data-toggle="tab" href="#contracthistory@(index)" role="tab" aria-selected="true">Contract History</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" data-toggle="tab" href="#farms@(index)" role="tab" aria-selected="false">Farms</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" data-toggle="tab" href="#spacemissions@(index)" role="tab" aria-selected="false">Space Missions</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" data-toggle="tab" href="#epicresearch@(index)" role="tab" aria-selected="false">Epic Research</a>
				</li>
				@if (inDB) {
					<li class="nav-item">
						<a class="nav-link" data-toggle="tab" href="#merits@(index)" role="tab" aria-selected="false">Merits (@merits.Count)</a>
					</li>
					@if (isAdmin) {
						<li class="nav-item">
							<a class="nav-link" data-toggle="tab" href="#demerits@(index)" role="tab" aria-selected="false">Demerits</a>
						</li>

					}
					@if (snapshots != null) {
						<li class="nav-item">
							<a class="nav-link" data-toggle="tab" href="#ebhistory@(index)" role="tab" aria-selected="false">EB History</a>
						</li>
					}
				}
				<li class="nav-item">
					<a class="nav-link" data-toggle="tab" href="#pe@(index)" role="tab" aria-selected="false">Eggs Of Prophecy</a>
				</li>
				<li class="nav-item">
					<a class="nav-link" data-toggle="tab" href="#externaltools@(index)" role="tab" aria-selected="false">External Tools</a>
				</li>
			</ul>

			<div class="tab-content">
				<div class="tab-pane" id="farms@(index)" role="tabpanel">
					@for (var i = 0; i < backup.Farms.Count; i++) {
						var farm = backup.Farms[i];


						if (farm.FarmType != Ei.FarmType.Empty) {
							var farmStats = farm.WithStats(backup);
							<div style="display: inline-block;" class="card">
								@if (farm.FarmType == Ei.FarmType.Home) {
									<h4 class="card-header"><img src="/images/Egg_@((int)farm.EggType).png" /> Home Farm</h4>
								} else if (farm.ContractId != null) {
									<h4 class="card-header"><img src="/images/Egg_@((int)farm.EggType).png" /> @contracts.FirstOrDefault(x => x.ID == farm.ContractId)?.Name</h4>
								} else {
									<h4 class="card-header">Error Finding Contract @farm.ContractId</h4>
								}
								<div class="card-body">
									@*<div>
						Egg Rate: @((farm.EggLayingRate * 60).ToEggString(true))
						</div>
						<div>
						Max Shipping Rate: @((farm.MaxShippingRate * 60).ToEggString(true))
						</div>
						<div>
						Current Shipping Rate: @((farm.CurrentShippingRate * 60).ToEggString(true))
						</div>
						<div>
						Egg Value: @((farm.EggValue).ToEggString(true))
						</div>
						<div>
						Income: @((farm.Income).ToEggString(true))
						</div>
						<div>
						Mystical Egg Bonus: @(backup.EarningsBonus.ToEggString(true))
						</div>
						<div>
						Max Running Bonus: @(farm.MaxRunningBonus)
						</div>
						<div>
						Income w/Running: @((farm.MaxRunningBonus * farm.Income).ToEggString(true))
						</div>*@
									<div style="display: inline-block;">
										Chickens: @farm.NumChickens.ToEggString()/
									</div>
									<div>
										Egg Rate: @((farmStats.EggLayingRate).ToEggString(true))/s
									</div>
									<div>
										Max Shipping Rate: @((farmStats.MaxShippingRate * 60).ToEggString(true))/m
									</div>
									<div>
										Current Shipping Rate: @((farmStats.CurrentShippingRate * 60).ToEggString(true))/m
									</div>
									<div>
										Hab Space: @farmStats.HabSpace.ToEggString()
									</div>
									<div>
										Base Internal Hatchery: @Research.InternalHatchery(farm, backup.EpicResearch)
									</div>
									<div id="@backup.EggIncId">
										Internal Hatchery: @farmStats.InternalHatchery/m
									</div>
									<div>
										Silo Time: @(Research.GetTotalSiloCapacity(backup) * farm.SilosOwned / 60)
									</div>
								</div>
								<div class="card-body" style="padding-bottom: 0;">
									<h6>Artifacts</h6>
								</div>
								<table class="table table-sm" style="margin-bottom: 0;">
									@if (farm.Artifacts.Count == 0) {
										<tr><td><i>No Artifacts</i></td></tr>
									}
									@foreach (var artifact in farm.Artifacts) {
										artifactTemplate(artifact);
										@if (artifact.Stones != null && artifact.Stones.Count > 0) {
											<td colspan="99" style="padding-left: 10px; ">
												<table>
													@foreach (var stone in artifact.Stones) {
														artifactTemplate(stone);
													}
												</table>
											</td>
										}
									}
								</table>
							</div>
						}
					}
				</div>

				<div class="tab-pane" id="spacemissions@(index)" role="tabpanel">
					@foreach (var mission in backup.SpaceMissions ?? new List<SpaceMission>()) {
						var returns = DateTimeOffset.FromUnixTimeSeconds((long)mission.StartTime + (long)mission.DurationSeconds);

						<div style="display: inline-block;" class="card">
							<h4 class="card-header">@mission.Ship.ToString().Replace("_", " ")</h4>
							<div class="card-body">
								<div>Status: @mission.Status</div>
								@switch (mission.Status) {
									case Ei.MissionInfo.Types.Status.Fueling:

										var fuelTargets = Ei.MissionInfo.GetFuelTargets(mission.Ship, mission.Duration);
										var needsFuel = mission == null || fuelTargets.Any(ft => ft.Value > (mission.Fuels.FirstOrDefault(f => f.Egg == ft.Key)?.Amount ?? 0));
										@needsFuel
										foreach (var fuel in mission.Fuels) {
											var target = fuelTargets[fuel.Egg];
											var percent = fuel.Amount / target * 100;
											<div>
												@fuel.Egg.ToString(): @Math.Round(percent)% full
											</div>
										}
										break;
									case Ei.MissionInfo.Types.Status.Exploring:
									case Ei.MissionInfo.Types.Status.Returned:
										if (returns < DateTimeOffset.Now) {
											<div>Returned: @((returns - DateTimeOffset.Now).Humanize(2).ShortenTime()) ago</div>

										} else {
											<div>Returns: @((returns - DateTimeOffset.Now).Humanize(2).ShortenTime())</div>
										}

										break;
								}
							</div>
						</div>
					}
				</div>

				<div class="tab-pane" id="epicresearch@(index)" role="tabpanel">
					@{
						await Html.RenderPartialAsync("-EpicResearch", (epicResearchConfig, backup));
					}
				</div>

				@if (inDB) {
					<div class="tab-pane" id="merits@(index)" role="tabpanel">
						@{
							foreach (var merit in merits) {
														<div>
															@merit.When.ToString("yyyy-M-d") @Html.Raw(emojiReplace.Replace(merit.Reason, emojiDelegage))
															@if (isAdmin) {
																<a href="/myfarms/removemerit?id=@merit.Id">X</a>
									}
														</div>
							}
						}
					</div>
					@if (isAdmin) {
						<div class="tab-pane" id="demerits@(index)" role="tabpanel">
							@{
								List<Demerit> demerits = ViewBag.Demerits;
								foreach (var demerit in demerits) {
															<div>
																@demerit.When.ToString("yyyy-M-d") @Html.Raw(emojiReplace.Replace(demerit.Reason, emojiDelegage)) <a href="/myfarms/removedemerit?id=@demerit.Id">X</a>
															</div>
								}
							}
						</div>
					}
					@if (snapshots != null) {
						<div class="tab-pane" id="ebhistory@(index)" role="tabpanel">
						@{await Html.RenderPartialAsync("-EBHistory", (backup, snapshots, isAdmin));}
						</div>
					}
				}
				<div class="tab-pane show active" id="contracthistory@(index)" role="tabpanel">
					@{
						await Html.RenderPartialAsync("-ContractHistory", (backup, isAdmin, contracts, Model));
					}
				</div>

				<div class="tab-pane" id="pe@(index)" role="tabpanel">
					<table class="table" style="width: auto;">
						<tr>
							<th>From Contracts</th>
							<td>@backup.ArchivedFarms.Sum(x => x.PEGained)</td>
						</tr>
						<tr>
							<th>From Daily Gifts</th>
							<td>@backup.PEFromDailyGifts of 24</td>
						</tr>
						<tr>
							<th>From Trophies</th>
							<td>@backup.PEFromTrophies of 40</td>
						</tr>
						<tr>
							<th>Total</th>
							<td>@backup.EggsOfProphecy</td>
						</tr>

					</table>

					<br />
					@{
						var nextRankInfo = SIPrefix.GetNextRankInfo(backup, false);
					}
					<h3>Needed for @nextRankInfo.First().Rank</h3>
					<table>
						<thead>
							<tr>
								<th>PE</th>
								<th>SE</th>
							</tr>
						</thead>
						<tbody>
							@{
								foreach (var ri in nextRankInfo) {
															<tr>
																<td>@ri.EggsOfProphecy</td>
																<td>@Math.Max(ri.SoulsEggs, 0).ToEggString()</td>
															</tr>
									if (ri.SoulsEggs < 0)
										break;
								}
							}
						</tbody>
					</table>

					@{
						nextRankInfo = SIPrefix.GetNextRankInfo(backup, true);
					}
					<h3>Needed for @nextRankInfo.First().Rank</h3>
					<table>
						<thead>
							<tr>
								<th>PE</th>
								<th>SE</th>
							</tr>
						</thead>
						<tbody>
							@{
								foreach (var ri in nextRankInfo) {
															<tr>
																<td>@ri.EggsOfProphecy</td>
																<td>@Math.Max(ri.SoulsEggs, 0).ToEggString()</td>
															</tr>
									if (ri.SoulsEggs < 0)
										break;
								}
							}
						</tbody>
					</table>

				</div>

				<div class="tab-pane" id="externaltools@(index)" role="tabpanel">
					@{
						await Html.RenderPartialAsync("-ExternalTools", (backup, Model));
					}
				</div>

			</div>
		</div>
	}
</div>

@{
	void artifactTemplate(EggIncArtifactInstance artifact) {
	<tr>
									<td>@artifact.Artifact</td>
									@if (artifact.Boost == EggIncBoostTypeEnum.HostArtifactsOnElightenment) {
										<td>@Math.Round((artifact.Value) * 100)%</td>
			} else if (artifact.Additive) {
										<td>+@artifact.Value</td>
			} else if (+artifact.Value < 2) {
										<td>+@Math.Round((artifact.Value - 1) * 100)%</td>
			} else {
										<td>@(artifact.Value)x</td>
			}
									<td>@artifact.Boost</td>
	</tr>
	}

