@model MyFarmsModel
@using Discord.WebSocket
@using EGG9000.Common.Helpers
@using Microsoft.AspNetCore.Html
@using static EGG9000.Site.Controllers.MyFarmsController
@using static EGG9000.Common.Helpers.EpicResearchCalc
@inject DiscordSocketClient discordClient
@{
    ViewData["Title"] = "Index";

    List<Contract> contracts = Model.Contracts;

    List<UserSnapShot> snapshots = Model.SnapShots;

    List<UserCoopXref> unjoinedCoops = Model.UnjoinedCoops.ToList();

    List<EpicResearchDetail> epicResearchConfig = Model.EpicResearchConfig;

    Dictionary<string, List<EGG9000.Common.Database.Entities.Contract>> uncompletePEs = Model.UncompletedPEContracts;

    List<(string EggIncId, Ei.MyContracts MyContracts)> scoring = Model.Scoring;
    Guild dbguild = Model.DBGuild;

    @*Func<EggIncArtifactInstance, object> artifactTemplate = @<span>
		<span>@item.Artifact</span>
		@if(item.Additive) {
		<span>+@item.Value</span>
		} else if(item.Value < 2) {
		<span>@Math.Round((item.Value - 1) * 100)%</span>
		} else {
		<span>@(item.Value)x</span>
		}
		<span>@item.Boost</span>
		</span>;*@

    var isAdmin = User.IsInRole("Admin") || User.IsInRole("GuildAdmin");
    var isLesserAdmin = isAdmin || User.IsInRole("GuildLesserAdmin");
    List<Ei.Backup> rawBackups = Model.RawBackups;


    var emojiReplace = new Regex(@"<:[^:]+:(\d+)>");

    string emojiDelegage(Match match) {
        return $"<img src='https://cdn.discordapp.com/emojis/{match.Groups[1]}.png?size=22' />";
    };
    List<Merit> merits = Model.Merits;
    var inDB = Model.User.DiscordId > 0;

}
<style>
    .card-header img {
        height: 50px;
        margin: -31px -8px -25px -22px;
    }

    .card {
        vertical-align: top;
    }

    .tight-emojis {
        letter-spacing: -0.5em;
    }

    .nobreak span {
        white-space: nowrap;
    }

    .tab-pane .container {
        padding: 0px;
    }
</style>

<script>
    function copyIdToClipboard(id, notifId) {
        // If the passed parameter is an HTML element, get its inner text
        const content = (typeof id === "object") ? id.innerText : id.toString();
        navigator.clipboard.writeText(content);

        if (notifId) {
            // Show the notification
            var notification = document.getElementById(notifId);
            notification.style.display = "block";
            notification.style.opacity = "1";

            // Hide the notification after 2 seconds (adjust the duration as needed)
            setTimeout(function () {
                notification.style.opacity = "0";
            }, 2000);
        }
    }
</script>

@if (isAdmin) {
    <h1>@Model.User.DiscordUsername Farms</h1>
} else {
    <h1>My Farms</h1>
}

@if (unjoinedCoops.Any()) {
    @if (isAdmin) {
        <div class="alert alert-danger">
            @Model.User.DiscordUsername has not joined the following coops they've been assigned.
            <div class="font-weight-bold" style="margin-top:10px;">
                @foreach (var xref in unjoinedCoops) {
                    <div><img style="max-height: 30px;" src="/images/Egg_@((int)xref.Coop.Contract.Details.Egg).png" />@xref.Coop.Contract.Name - @xref.Coop.Name<a href="discord://discordapp.com/channels/@xref.Coop.OverflowGuildId/@xref.Coop.DiscordChannelId/"><img src="/images/discordicon.png" style="max-height: 1em;" /></a></div>
                }
            </div>
        </div>
    } else {
        <div class="alert alert-danger">
            Pssst... It looks like you haven't joined the following coops that you've been assigned!
            <div class="font-weight-bold" style="margin-top:10px;">
                @foreach (var xref in unjoinedCoops) {
                    <div>><img style="max-height: 30px;" src="/images/Egg_@((int)xref.Coop.Contract.Details.Egg).png" />@xref.Coop.Contract.Name - @xref.Coop.Name<a href="discord://discordapp.com/channels/@xref.Coop.OverflowGuildId/@xref.Coop.DiscordChannelId/"><img src="/images/discordicon.png" style="max-height: 1em;" /></a></div>
                }
            </div>
        </div>
    }
}

<div>
    @if (isLesserAdmin) {
        if (Model.User.TempDisabled) {
            <span style="color: #FF0000">❗User is disabled</span>
        }
    }
</div>

<div style="padding-bottom: 10px;">
    <span style="margin-right:10px;"><b><u>Discord Name</u></b>: @Model.User.DiscordUsername</span>
    <span style="margin:5px;" title="Click to copy" id="discord-id-copy-button" onclick="copyIdToClipboard('@Model.User.DiscordId', 'copy-notification-discord')"><b><u>Discord ID</u></b>: @Model.User.DiscordId</span>
    <div class="copy-notification" id="copy-notification-discord">Discord ID copied!</div>
    @if (Model.User.GuildId == 0) {
        <span style="margin:5px; color: #FFAA33;">⚠️ Not currently a member of a Discord server, might need to run /moveserver if you are supposed to be</span>
    } else {
        <span style="margin:5px;"><b><u>Member of</u></b>: @(discordClient.Guilds.FirstOrDefault(x => x.Id == Model.User.GuildId)?.Name ?? "unknown")</span>
    }
</div>


@if (Model.User.EggIncAccounts.Count > 1) {
    <ul class="nav nav-tabs" role="tablist">
        @for (var index = 0; index < Model.User.EggIncAccounts.Count; index++) {
            var account = Model.User.EggIncAccounts[index];
            <li class="nav-item">
                <a class="nav-link @(index == 0 ? "active" : "")" id="tab@(account.Id)" data-toggle="tab" href="#user@(index)" role="tab" aria-selected="@(index == 0)">
                    @account.Backup.UserName
                    <img src="@PlayerGradeDetails.GetImage(account.GetGrade())" style="max-height: 23px;" />
                    @if (account.Backup.PermitLevel == 0) {
                        <img src="https://cdn.discordapp.com/emojis/755734059761795173.png?v=1" style="max-height: 23px;" />
                    } else {
                        <img src="https://cdn.discordapp.com/emojis/724392625276452955.png?v=1" style="max-height: 23px;" />
                    }
                </a>
            </li>
        }
    </ul>
}

<div class="tab-content">
    @for (var index = 0; index < Model.User.EggIncAccounts.Count; index++) {
        var account = Model.User.EggIncAccounts[index];
        var backup = account.Backup;
        //Remove existing "tank" and "hyperloop" options
        epicResearchConfig.Remove(epicResearchConfig.FirstOrDefault(x => x.Title == "Hyperloop"));
        epicResearchConfig.Remove(epicResearchConfig.FirstOrDefault(x => x.Title == "Fuel Tank"));
        var rawBackup = rawBackups.First(x => x.EiUserId == backup.EggIncId);
        <div class="tab-pane @(index == 0 ? "show active" : "")" id="user@(index)" role="tabpanel">
            <div style="padding-bottom: 10px;" class="nobreak">
                @if (Model.User.EggIncAccounts.Count == 1) {
                    @:<span style="margin-right:10px;"><b><u>In-Game Name</u></b>: @backup.UserName</span>
                    <img src="@PlayerGradeDetails.GetImage(account.GetGrade())" style="max-height: 23px;" />
                    @if (backup.PermitLevel == 0) {
                        <img src="https://cdn.discordapp.com/emojis/755734059761795173.png?v=1" style="max-height: 23px;" />
                    } else {
                        <img src="https://cdn.discordapp.com/emojis/724392625276452955.png?v=1" style="max-height: 23px;" />
                    }
                }
                <span style="margin-right:10px;" onclick="copyIdToClipboard('@backup.EggIncId', 'copy-notification-eid-@index')" title="Click to copy"><b><u>EggIncId</u></b>: @backup.EggIncId</span>
                <div class="copy-notification" id="copy-notification-eid-@index">EID copied!</div>
                <span style="margin-right:10px;"><b><u>Last Backup</u></b>: @((DateTimeOffset.Now - DateTimeOffset.FromUnixTimeSeconds(backup.LastBackupTime)).Humanize())</span><br>
                @if (!dbguild.DisableBG) {
                    if (account.Group == 0) {
                        <span style="margin-right:10px;; color: #FFAA33"><b>⚠️Boarding Group Not Set</b></span>
                    } else {
                        <span style="margin-right:10px;"><b><u>Boarding Group @account.Group</u></b></span>
                    }
                }
                @if (account.OnBreakUntil > DateTimeOffset.Now) {
                    <span style="margin-right:10px;" title="Date/Time displayed in local time"><b><u>On Break until</u></b>: @account.OnBreakUntil.ToLocalTime().ToString("yyyy-MM-dd h:mm:ss tt")</span>
                }
                @if ((account.AutoRegisterRewards?.Count ?? 0) > 0) {
                    <span style="margin-right:10px;"><b><u>Filter</u></b>: @string.Join(",", account.AutoRegisterRewards)</span>
                } else {
                    <span style="margin-right:10px;"><b><u>Filter</u></b>: All</span>
                }
                <span style="margin-right:10px;">
                    <b><u>Redo Leggacies</u></b>:
                    @if (account.RedoLeggacySelection == RedoLeggacyOption.YesAll) {
                        @string.Join("", "Yes (All)")
                    } else if (account.RedoLeggacySelection == RedoLeggacyOption.YesThreshold) {
                        @string.Join("", $"Yes (Under {account.RedoScoreThreshold} CS)")
                    } else {
                        @string.Join("", "No")
                    }
                </span>
            </div>

            <ul class="nav nav-tabs" role="tablist">
                <li class="nav-item">
                    <a class="nav-link active" data-toggle="tab" href="#contracthistory@(index)" role="tab" aria-selected="true">Contract History</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#shipsfarms@(index)" role="tab" aria-selected="false">Ships & Farms</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#epicresearch@(index)" role="tab" aria-selected="false">Epic Research</a>
                </li>
                @if (inDB) {
                    var tabName = isAdmin ? $"Merits ({merits.Count}) & Demerits" : $"Merits ({merits.Count})";
                    <li class="nav-item">
                        <a class="nav-link" data-toggle="tab" href="#merits@(index)" role="tab" aria-selected="false">@tabName</a>
                    </li>
                    @if (snapshots != null) {
                        <li class="nav-item">
                            <a class="nav-link" data-toggle="tab" href="#ebhistory@(index)" role="tab" aria-selected="false">EB Stats</a>
                        </li>
                    }
                }
                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#artifactcombos@(index)" role="tab" aria-selected="false">Artifact Combos</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#externaltools@(index)" role="tab" aria-selected="false">External Tools</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-toggle="tab" href="#earningsboostcalc@(index)" role="tab" aria-selected="false">Earnings Boost Calc</a>
                </li>
            </ul>

            <div class="tab-content">
                <div class="tab-pane" style="margin-top:20px" id="shipsfarms@(index)" role="tabpanel">
                    <div id="shipsDiv" class="ship-container">
                        @foreach (var mission in backup.SpaceMissions ?? new List<SpaceMission>()) {
                            var returns = DateTimeOffset.FromUnixTimeSeconds((long)mission.StartTime + (long)mission.DurationSeconds);

                            var shipEmoji = mission.Ship switch {
                                Ei.MissionInfo.Types.Spaceship.ChickenOne => "807223532747620373",
                                Ei.MissionInfo.Types.Spaceship.ChickenNine => "801748829212508161",
                                Ei.MissionInfo.Types.Spaceship.ChickenHeavy => "801748846455554088",
                                Ei.MissionInfo.Types.Spaceship.Bcr => "801748795498430464",
                                Ei.MissionInfo.Types.Spaceship.MilleniumChicken => "801748939354931200",
                                Ei.MissionInfo.Types.Spaceship.CorellihenCorvette => "801748884061159465",
                                Ei.MissionInfo.Types.Spaceship.Galeggtica => "801748910607171644",
                                Ei.MissionInfo.Types.Spaceship.Chickfiant => "801748897243987978",
                                Ei.MissionInfo.Types.Spaceship.Voyegger => "801748952814845962",
                                Ei.MissionInfo.Types.Spaceship.Henerprise => "801748924146384906",
                                _ => ""
                            };
                            var shipEmojiLink = "https://cdn.discordapp.com/emojis/" + shipEmoji + ".png?v=1";

                            <div class="ship-item card" style="display: inline-block; text-align: center; margin: 10px; padding-top: 10px">
                                @if (shipEmoji != "") {
                                    <img src="@((shipEmojiLink))" style="max-height: 40px">
                                }
                                <h4 class="card-header">@mission.Ship.ToString().Replace("_", " ")</h4>
                                <div class="card-body">
                                    <div>Status: @mission.Status</div>
                                    @switch (mission.Status) {
                                        case Ei.MissionInfo.Types.Status.Fueling:

                                            var fuelTargets = Ei.MissionInfo.GetFuelTargets(mission.Ship, mission.Duration);
                                            var needsFuel = mission == null || fuelTargets.Any(ft => ft.Value > (mission.Fuels.FirstOrDefault(f => f.Egg == ft.Key)?.Amount ?? 0));
                                            <div>Needs Fuel: @needsFuel</div>
                                            foreach (var fuel in mission.Fuels) {
                                                var target = fuelTargets[fuel.Egg];
                                                var percent = fuel.Amount / target * 100;
                                                <div>
                                                    @fuel.Egg.ToString(): @Math.Round(percent)% full
                                                </div>
                                            }
                                            break;
                                        case Ei.MissionInfo.Types.Status.Exploring:
                                        case Ei.MissionInfo.Types.Status.Returned:
                                            if (returns < DateTimeOffset.Now) {
                                                <div>Returned: @((returns - DateTimeOffset.Now).Humanize(2).ShortenTime()) ago</div>
                                            } else {
                                                <div>Returns: @((returns - DateTimeOffset.Now).Humanize(2).ShortenTime())</div>
                                            }
                                            break;
                                    }
                                    <div>Capacity: @((mission.Capacity))</div>
                                    <!-- Only quintillion (4) and above can be targeted ships-->
                                    @if (((int)mission?.Ship >= 4) && mission?.Targeting != null) {
                                        @switch (mission?.Targeting) {
                                            case Ei.ArtifactSpec.Types.Name.Unknown:
                                                <div>Targeting: None</div>
                                                break;
                                            default:
                                                <div>Targeting: @((mission.Targeting))</div>
                                                break;
                                        }
                                    }
                                </div>
                            </div>
                        }
                    </div>
                    <br />
                    <hr />
                    <br />
                    @for (var i = 0; i < backup.Farms.Count; i++) {
                        var farm = backup.Farms[i];


                        if (farm.FarmType != Ei.FarmType.Empty) {
                            var coop = Model.JoinedCoops.FirstOrDefault(x => x.Name.Equals(farm.CoopId, StringComparison.InvariantCultureIgnoreCase));
                            var farmStats = farm.WithStats(backup, coop);
                            <div style="display: inline-block;" class="card">
                                @if (farm.FarmType == Ei.FarmType.Home) {
                                    <h4 class="card-header"><img src="/images/Egg_@((int)farm.EggType).png" /> Home Farm</h4>
                                } else if (farm.ContractId != null) {
                                    <h4 class="card-header"><img src="/images/Egg_@((int)farm.EggType).png" /> @contracts.FirstOrDefault(x => x.ID == farm.ContractId)?.Name</h4>
                                } else {
                                    <h4 class="card-header">Error Finding Contract @farm.ContractId</h4>
                                }
                                <div class="card-body">
                                    <div style="display: inline-block;">
                                        Chickens: @farm.NumChickens.ToEggString()
                                    </div>
                                    <div>
                                        Egg Rate: @((farmStats.EggLayingRate * 60).ToEggString(true))/m
                                    </div>
                                    <div>
                                        Max Shipping Rate: @((farmStats.MaxShippingRate * 60).ToEggString(true))/m
                                    </div>
                                    <div>
                                        Current Shipping Rate: @((farmStats.CurrentShippingRate * 60).ToEggString(true))/m (@((farmStats.CurrentShippingRate).ToEggString(true, 3))/s)
                                    </div>
                                    <div>
                                        Hab Space: @farmStats.HabSpace.ToEggString()
                                    </div>
                                    <div>
                                        Base Internal Hatchery: @Research.InternalHatchery(farm, backup.EpicResearch)
                                    </div>
                                    <div id="@backup.EggIncId">
                                        Internal Hatchery: @farmStats.InternalHatchery/m
                                    </div>
                                    <div>
                                        Silo Time: @(Research.GetTotalSiloCapacity(backup) * farm.SilosOwned / 60)
                                    </div>
                                    @if (coop is not null) {
                                        <div>
                                            Coop:
                                            <a href="/coop/@farm.ContractId/@(farm.CoopId ?? coop?.Name)">
                                                @(farm.CoopId ?? coop?.Name)
                                            </a>
                                            @if (coop is not null && !coop.DeletedChannel) {
                                                <a href="discord://discordapp.com/channels/@coop.OverflowGuildId/@coop.DiscordChannelId/"><img src="/images/discordicon.png" style="max-height: 1em;" /></a>
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="card-body" style="padding-bottom: 0;">
                                    <h6>Artifacts</h6>
                                </div>
                                <table class="table table-sm" style="margin-bottom: 0;">
                                    @if (farm.Artifacts.Count == 0) {
                                        <tr><td><i>No Artifacts</i></td></tr>
                                    }
                                    @foreach (var artifact in farm.Artifacts) {
                                        artifactTemplate(artifact);
                                        @if (artifact.Stones != null && artifact.Stones.Count > 0) {
                                            <td colspan="99" style="padding-left: 10px; ">
                                                <table>
                                                    @foreach (var stone in artifact.Stones) {
                                                        artifactTemplate(stone);
                                                    }
                                                </table>
                                            </td>
                                        }
                                    }
                                </table>
                            </div>
                        }
                    }
                </div>

                <div class="tab-pane" id="epicresearch@(index)" role="tabpanel">
                    @{
                        await Html.RenderPartialAsync("-EpicResearch", (epicResearchConfig, backup));
                    }
                </div>
                <div class="tab-pane" id="artifactcombos@(index)" role="tabpanel">
                    @{
                        await Html.RenderPartialAsync("-ArtifactCombos", (backup, contracts, Model.JoinedCoops, Model.User));
                    }
                </div>

                @if (inDB) {
                    <div class="tab-pane" id="merits@(index)" role="tabpanel">
                        <div class="container">
                            <div class="row">
                                <div class="col-sm">
                                    @{
                                        <div class="card" style="margin-top:20px">
                                            <table class="table table-striped">
                                                <caption style="caption-side: top; text-align: center; font-weight: bold;"><u>Merits</u></caption>
                                                @if (merits.Count > 0) {
                                                    <tbody>
                                                        <tr>
                                                            <th class="text-left">Date</th>
                                                            <th>Reason</th>
                                                            @if (isAdmin) {
                                                                <th></th>
                                                            }
                                                        </tr>
                                                    </tbody>
                                                    <tbody>
                                                        @foreach (var merit in merits) {
                                                            <tr>
                                                                <td>@merit.When.ToString("yyyy-MM-dd")</td>
                                                                <td> @Html.Raw(emojiReplace.Replace(merit.Reason, emojiDelegage))</td>
                                                                @if (isAdmin) {
                                                                    <td><a href="/myfarms/removemerit?id=@merit.Id" title="Remove Merit">X</a></td>
                                                                }
                                                            </tr>
                                                        }
                                                    </tbody>
                                                } else {
                                                    <tr style="padding: 20px; margin-top:20px; text-align: center">
                                                        <td>No merits for user.</td>
                                                    </tr>
                                                }
                                            </table>
                                        </div>



                                    }
                                </div>
                                <div class="col-sm">
                                    @{
                                        List<Demerit> demerits = Model.Demerits;
                                        <div class="card" style="margin-top:20px">
                                            <table class="table table-striped">
                                                <caption style="caption-side: top; text-align: center; font-weight: bold;">Demerits</caption>
                                                @if (demerits.Count > 0 && isAdmin) {
                                                    <thead>
                                                        <tr>
                                                            <th class="text-left">Date</th>
                                                            <th>Reason</th>
                                                            @if (isAdmin) {
                                                                <th></th>
                                                            }
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var demerit in demerits) {
                                                            <tr>
                                                                <td>@demerit.When.ToString("yyyy-MM-dd")</td>
                                                                <td> @Html.Raw(emojiReplace.Replace(demerit.Reason, emojiDelegage))</td>
                                                                @if (isAdmin) {
                                                                    <td><a href="/myfarms/removedemerit?id=@demerit.Id" title="Remove Demerit">X</a></td>
                                                                }
                                                            </tr>
                                                        }
                                                    </tbody>
                                                } else {
                                                    <tbody>
                                                        <tr style="text-align: center">
                                                            <td style="text-align: center">
                                                                <span style="display: inline-block; padding: 20px;">No demerits for user.</span>
                                                            </td>
                                                        </tr>
                                                    </tbody>
                                                }
                                            </table>
                                        </div>



                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                    @if (snapshots != null) {
                        <div class="tab-pane" id="ebhistory@(index)" role="tabpanel">
                            @{
                                await Html.RenderPartialAsync("-EBHistory", (backup, snapshots, isAdmin, uncompletePEs, contracts));
                            }
                        </div>
                    }
                }
                <div class="tab-pane show active" id="contracthistory@(index)" role="tabpanel">
                    @{
                        Ei.MyContracts scores = scoring.Any(x => x.EggIncId == backup.EggIncId) ? scoring.First(x => x.EggIncId == backup.EggIncId).MyContracts : null;
                        await Html.RenderPartialAsync("-ContractHistory", (backup, isAdmin, contracts, Model.User, scores));
                    }
                </div>

                <div class="tab-pane" id="externaltools@(index)" role="tabpanel">
                    @{
                        await Html.RenderPartialAsync("-ExternalTools", (backup, Model.User));
                    }
                </div>

                <div class="tab-pane" id="earningsboostcalc@(index)" role="tabpanel">
                    @{
                        var newModel = new EarningsBoostCalculatorModel();
                        newModel.Backup = backup;
                        await Html.RenderPartialAsync("-EarningsBoostCalculator", (newModel));
                    }
                </div>

            </div>
        </div>
    }
</div>

@{
    void artifactTemplate(EggIncArtifactInstance artifact) {
        <tr>
            <td>@artifact.Artifact</td>
            @if (artifact.Boost == EggIncBoostTypeEnum.HostArtifactsOnElightenment) {
                <td>@Math.Round((artifact.Value) * 100)%</td>
            } else if (artifact.Additive) {
                <td>+@artifact.Value</td>
            } else if (+artifact.Value < 2) {
                <td>+@Math.Round((artifact.Value - 1) * 100)%</td>
            } else {
                <td>@(artifact.Value)x</td>
            }
            <td>@artifact.Boost</td>
        </tr>
    }

    //(IHtmlContent, DateTimeOffset) GetActiveFarm(CustomFarm farm) {
    //	var coop = Model.UserCoopXrefs.FirstOrDefault(x => x.Coop.ContractID == farm.ContractId)?.Coop;
    //	var xref = Model.UserCoopXrefs.FirstOrDefault(x => x.Coop.ContractID == farm.ContractId);
    //	var lastUpdate = xref?.Coop?.LastStatusUpdate?.Contributors.FirstOrDefault(c => c.UserId == xref.EggIncId);
    //	var contract = contracts.FirstOrDefault(x => x.ID == farm.ContractId);
    //	IHtmlContent html =
    //@<tr>
    //		<td>@(contract?.Name ?? farm.ContractId)</td>
    //		<td>
    //			<a href="/coop/@farm.ContractId/@(farm.CoopId ?? coop?.Name)">
    //				@(farm.CoopId ?? coop?.Name)
