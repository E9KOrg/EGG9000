@model (CustomBackup backup, List<UserSnapShot> snapshots, bool isAdmin, Dictionary<string, List<EGG9000.Common.Database.Entities.Contract>> uncompletePEs)

<script>
	function toggleRows() {
		var el = document.getElementById('content-collapse');
		if(el.style.display == 'table-row-group'){
			el.style.display = 'none';
			document.getElementById('collapsePE').innerHTML = "Show";
			document.getElementById('altNotShownBody').style.display = 'table-row-group';
		} else {
			el.style.display = 'table-row-group';
			document.getElementById('collapsePE').innerHTML = "Hide";
			document.getElementById('altNotShownBody').style.display = 'none';
		}
	}
</script>

@if (Model.uncompletePEs[Model.backup.EggIncId].Count() > 0)
{
	<div class="card" style="margin-top:15px;">
		<h4 class="card-header" style="text-align: center"> <button class="btn-sm btn btn-outline-primary" id="collapsePE" onclick="toggleRows()">Show</button> Unobtained Contract Eggs of Prophecy</h4>
		<table class="table table-sm align-middle collapsible-table table-striped">
			<thead>
				<tr class="collapsible-row">
					<th style="text-align: left">Contract Name</th>
					<th style="text-align: left">Contract ID</th>
					<th style="text-align: left">Last Leggacied</th>
				</tr>
			</thead>
			<tbody id="content-collapse" style="display: none">
				@foreach (var contract in Model.uncompletePEs[Model.backup.EggIncId].OrderBy(c => c.Created).ToList())
				{
					<tr class="collapsible-row">
						<td>@contract.Name</td>
						<td>@contract.ID</td>
						<td>@contract.Created.ToString("yyyy-MM-dd")</td>
					</tr>
				}
			</tbody>
			<tbody id="altNotShownBody">
				<tr>
					<td colspan="3" style="text-align: center; color:coral">
						<b>@Model.uncompletePEs[Model.backup.EggIncId].Count() rows hidden</b>
					</td>
				</tr>
			</tbody>
		</table>
	</div>
}

<div class="card">
	<h4 class="card-header" style="text-align: center">Egg of Prophecy Progress</h4>
	<div class="table-responsive">
