@model (CustomBackup backup, List<UserSnapShot> snapshots, bool isAdmin, Dictionary<string, List<EGG9000.Common.Database.Entities.Contract>> uncompletePEs, List<Contract> contracts, (int Earned, int Max) peFromSeasons, List<EGG9000.Site.Controllers.MyFarmsController.MissingSeasonalPe> missingSeasonalPEs)
@{
    double merValue(double se, double pe) =>
        (se > 0 && double.IsFinite(se)) ? (91.0 * Math.Log10(se / 1e18) + 200.0 - pe) / 10.0 : 0.0;

    string calculateMER(double se, ulong pe) {
        var result = merValue(se, (double)pe);
        return String.Format(result % 1 == 0 ? "{0:0}" : "{0:0.00}", result);
    }

    string displayKey(UserSnapShot s) =>
        $"{s.EggsOfProphecy}|{s.EggsOfTruth}|{s.SoulEggs.ToEggString(numberOfDecimalPlaces: 3)}|{s.EarningsBonus.ToEggString(numberOfDecimalPlaces: 3)}|{s.Prestiges}";

    // Collapse consecutive snapshots that render identically at the table's precision.
    // Each surviving row keeps the earliest date its values appeared.
    var collapsedSnapshots = new List<UserSnapShot>();
    foreach (var s in Model.snapshots.Where(x => x.EggIncID == Model.backup.EggIncId).OrderByDescending(x => x.Date)) {
        if (collapsedSnapshots.Count > 0 && displayKey(collapsedSnapshots[^1]) == displayKey(s)) collapsedSnapshots[^1] = s;
        else collapsedSnapshots.Add(s);
    }

    var makePoint = (DateTime date, double eb, double se, double pe, double eot) => new {
        date = date.ToString("yyyy-MM-dd"),
        logEb = (eb > 0 && double.IsFinite(eb)) ? Math.Log10(eb) : 0.0,
        ebStr = eb.ToEggString(numberOfDecimalPlaces: 3),
        logSe = (se > 0 && double.IsFinite(se)) ? Math.Log10(se) : 0.0,
        seStr = se.ToEggString(numberOfDecimalPlaces: 3),
        pe,
        eot,
        mer = merValue(se, pe)
    };

    var ebStatsPoints = collapsedSnapshots
        .OrderBy(s => s.Date)
        .Select(s => makePoint(s.Date, s.EarningsBonus, s.SoulEggs, (double)s.EggsOfProphecy, (double)s.EggsOfTruth))
        .Append(makePoint(DateTime.Today, Model.backup.EarningsBonus, Model.backup.SoulEggs, (double)Model.backup.EggsOfProphecy, (double)Model.backup.EggsOfTruth))
        .ToArray();

    var ebStatsJson = JsonConvert.SerializeObject(ebStatsPoints, new JsonSerializerSettings { FloatFormatHandling = FloatFormatHandling.DefaultValue });
    var ebStatsSuffix = Regex.Replace(Model.backup.EggIncId, @"[^a-zA-Z0-9]", "");
}

<div class="container">

    <!-- FULL-WIDTH EXPANDED ROW (hidden by default) -->
    <div class="row" id="ebStatsFullRow-@(ebStatsSuffix)" style="display:none; margin-top:15px;">
        <div class="col-12">
            <div class="card">
                <h4 class="card-header d-flex justify-content-between align-items-center">
                    <span>Progress Graph</span>
                    <div>
                        <button class="btn btn-sm btn-primary me-1"           id="ebStatsBtn-eb-full-@(ebStatsSuffix)"  onclick="ebStatsToggle_@(ebStatsSuffix)('eb')">EB</button>
                        <button class="btn btn-sm btn-outline-secondary me-1" id="ebStatsBtn-se-full-@(ebStatsSuffix)"  onclick="ebStatsToggle_@(ebStatsSuffix)('se')">SE</button>
                        <button class="btn btn-sm btn-outline-secondary me-1" id="ebStatsBtn-pe-full-@(ebStatsSuffix)"  onclick="ebStatsToggle_@(ebStatsSuffix)('pe')">PE</button>
                        <button class="btn btn-sm btn-outline-secondary me-1" id="ebStatsBtn-eot-full-@(ebStatsSuffix)" onclick="ebStatsToggle_@(ebStatsSuffix)('eot')">EoT</button>
                        <button class="btn btn-sm btn-outline-secondary me-1" id="ebStatsBtn-mer-full-@(ebStatsSuffix)" onclick="ebStatsToggle_@(ebStatsSuffix)('mer')">MER</button>
                        <button class="btn btn-sm btn-outline-primary"        id="ebStatsCollapse-@(ebStatsSuffix)"     onclick="ebStatsCollapse_@(ebStatsSuffix)()">&#x26F6; Collapse</button>
                    </div>
                </h4>
                <div class="card-body p-2">
                    <div id="ebStatsChartFull-@(ebStatsSuffix)"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- NORMAL TWO-COLUMN ROW -->
    <div class="row" id="ebStatsNarrowRow-@(ebStatsSuffix)">
        <div class="col-sm">
            <div class="card" style="margin-top:15px;">
                <h4 class="card-header" style="text-align: center">Egg of Prophecy Progress</h4>
                <div class="table-responsive">
                    <table class="table align-middle table-striped">
                        <thead>
                            <tr>
                                <th style="text-align: left">From Contracts</th>
                                <th style="text-align: left">From Daily Gifts</th>
                                <th style="text-align: left">From Trophies</th>
                                <th style="text-align: left">From Season Rewards</th>
                                <th style="text-align: left">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                @{
                                    var goalsWithPE = Model.contracts.Select(x => (x.Details.GradeSpecs?.FirstOrDefault()?.Goals ?? x.Details.GoalSets?.FirstOrDefault()?.Goals ?? x.Details.Goals).FirstOrDefault(y => y.RewardType == Ei.RewardType.EggsOfProphecy)).Where(x => x is not null);
                                    <td>
                                         @Model.backup.ArchivedFarms.Sum(x => x.PEGained) of @goalsWithPE.Sum(x => x.RewardAmount) </td>
                                }
                                <td>@Model.backup.PEFromDailyGifts of 24</td>
                                <td>@Model.backup.PEFromTrophies of 40</td>
                                <td>@Model.peFromSeasons.Earned@(Model.peFromSeasons.Max > 0 ? $" of {Model.peFromSeasons.Max}" : "")</td>
                                <td>@Model.backup.EggsOfProphecy</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            @if (Model.missingSeasonalPEs.Count > 0) {
                <div class="card" style="margin-top:15px;">
                    <h4 class="card-header" style="text-align: center">Missing Seasonal Eggs of Prophecy</h4>
                    <div class="card-body">
                        @foreach (var season in Model.missingSeasonalPEs) {
                            var pct = Math.Min(100, season.GoalCxp > 0 ? season.CurrentCxp / season.GoalCxp * 100 : 0);
                            <div style="margin-bottom:12px;">
                                <div class="d-flex justify-content-between align-items-center" style="margin-bottom:4px;">
                                    <span><b>@season.SeasonName</b></span>
                                    <span><span class="text-info">@season.CurrentCxp.ToString("N0")</span> / @season.GoalCxp.ToString("N0") CS</span>
                                    <span><img src="/images/Egg_of_Prophecy.png" style="max-height: 1.2em;" alt="Egg of Prophecy" /></span>
                                </div>
                                <div class="progress" role="progressbar" aria-valuenow="@((int)pct)" aria-valuemin="0" aria-valuemax="100">
                                    <div class="progress-bar bg-success" style="width:@pct.ToString(System.Globalization.CultureInfo.InvariantCulture)%"></div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (Model.uncompletePEs[Model.backup.EggIncId].Count() > 0) {
                <div class="card" style="margin-top:15px;">
                    <h4 class="card-header" style="text-align: center">
                        @if (Model.uncompletePEs[Model.backup.EggIncId].Count() != 0) {
                            <button class="btn-sm btn btn-outline-primary" id="collapsePE" onclick="$('.collapsible-row').toggleClass('toggleHide')">Toggle Hidden</button>
                            <br />
                        }
                        Missing Contract Eggs of Prophecy
                    </h4>
                    <table class="table table-sm align-middle collapsible-table table-striped">
                        <thead>
                            <tr>
                                <th style="text-align: left">Contract Name</th>
                                <th style="text-align: left">Contract ID</th>
                                <th style="text-align: left">Last Seen</th>
                                <th>PE</th>
                            </tr>
                        </thead>
                        <tbody id="content-collapse">
                            @if(Model.uncompletePEs[Model.backup.EggIncId].Count() == 0){
                                <tr class="collapsible-row toggleHide">
                                    <td colspan="4" style="text-align: center;">You've gathered all Prophecy Eggs from Contracts.<br /><a class="nav-link text-primary" href="https://rroll.to/iHgSMg" target="_blank" rel="nofollow">Ready to take the next challenge?</a></td>
                                </tr>
                            } else {
                                @foreach (var contract in Model.uncompletePEs[Model.backup.EggIncId].OrderBy(c => c.Created).ToList()) {
                                    <tr class="collapsible-row toggleHide">
                                        <td>@contract.Name</td>
                                        <td>@contract.ID</td>
                                        <td>@contract.Created.ToString("yyyy-MM-dd")</td>
                                        <td>@contract.Details.GetPossiblePE()</td>
                                    </tr>
                                }
                            }
                        </tbody>
                        <tbody id="altNotShownBody">
                            <tr class="collapsible-row toggleHide">
                                <td colspan="3" style="text-align: center; color:coral">
                                    <b>@Model.uncompletePEs[Model.backup.EggIncId].Count() contracts hidden (@Model.uncompletePEs[Model.backup.EggIncId].Sum(x => x.Details.GetPossiblePE()) PEs)</b>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            }

        </div>
        <div class="col-sm">
            <!-- CHART CARD (narrow, default visible) -->
            <div class="card" style="margin-top:15px;" id="ebStatsNarrowCard-@(ebStatsSuffix)">
                <h4 class="card-header d-flex justify-content-between align-items-center flex-wrap gap-1">
                    <span style="white-space: nowrap; margin-right: 8px;">Progress Graph</span>
                    <div class="d-flex flex-wrap gap-1">
                        <button class="btn btn-sm btn-primary me-1"           id="ebStatsBtn-eb-@(ebStatsSuffix)"  onclick="ebStatsToggle_@(ebStatsSuffix)('eb')">EB</button>
                        <button class="btn btn-sm btn-outline-secondary me-1" id="ebStatsBtn-se-@(ebStatsSuffix)"  onclick="ebStatsToggle_@(ebStatsSuffix)('se')">SE</button>
                        <button class="btn btn-sm btn-outline-secondary me-1" id="ebStatsBtn-pe-@(ebStatsSuffix)"  onclick="ebStatsToggle_@(ebStatsSuffix)('pe')">PE</button>
                        <button class="btn btn-sm btn-outline-secondary me-1" id="ebStatsBtn-eot-@(ebStatsSuffix)" onclick="ebStatsToggle_@(ebStatsSuffix)('eot')">EoT</button>
                        <button class="btn btn-sm btn-outline-secondary me-1" id="ebStatsBtn-mer-@(ebStatsSuffix)" onclick="ebStatsToggle_@(ebStatsSuffix)('mer')">MER</button>
                        <button class="btn btn-sm btn-outline-primary"        id="ebStatsExpand-@(ebStatsSuffix)"  onclick="ebStatsExpand_@(ebStatsSuffix)()">&#x26F6; Expand</button>
                    </div>
                </h4>
                <div class="card-body p-2">
                    <div id="ebStatsChartNarrow-@(ebStatsSuffix)"></div>
                </div>
            </div>
            <!-- EXISTING EB HISTORY TABLE (unchanged) -->
            <div class="card" style="margin-top:15px;">
                <h4 class="card-header" style="text-align: center;">Earnings Bonus History</h4>
                <div class="table-responsive">
                    <table class="table table-striped">

                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>PE</th>
                                <th>EoT</th>
                                <th style="text-align: right !important;">Soul Eggs</th>
                                <th style="text-align: right !important;">EB</th>
                                <th style="text-align: right !important;">MER</th>
                                <th>Prestiges</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Latest</td>
                                <td>@Model.backup.EggsOfProphecy</td>
                                <td>@Model.backup.EggsOfTruth</td>
                                <td align="right">@Model.backup.SoulEggs.ToEggString(numberOfDecimalPlaces: 3)</td>
                                <td align="right">@Model.backup.EarningsBonus.ToEggString(numberOfDecimalPlaces: 3)</td>
                                <td align="right">@calculateMER(Model.backup.SoulEggs, Model.backup.EggsOfProphecy).ToString()</td>
                                <td>@Model.backup.NumPrestiges</td>
                            </tr>
                            @foreach (var snapshot in collapsedSnapshots) {
                                <tr>
                                    <td>@snapshot.Date.ToString("yyyy-MM-dd")</td>
                                    <td>@snapshot.EggsOfProphecy</td>
                                    <td>
                                        @if(snapshot.EggsOfTruth > 0) {
                                            @snapshot.EggsOfTruth
                                        }
                                    </td>
                                    <td align="right">@snapshot.SoulEggs.ToEggString(numberOfDecimalPlaces: 3)</td>
                                    <td align="right">@snapshot.EarningsBonus.ToEggString(numberOfDecimalPlaces: 3)</td>
                                    <td align="right">@calculateMER(snapshot.SoulEggs, snapshot.EggsOfProphecy).ToString()</td>
                                    <td>@snapshot.Prestiges</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>
<style>
    .toggleHide {
        display: none;
    }

    #altNotShownBody tr {
        display: none;
    }

    #altNotShownBody .toggleHide {
        display: table-row;
    }

    @@media (min-width: 992px) {

        #content-collapse tr {
            display: none;
        }

        #content-collapse .toggleHide {
            display: table-row;
        }

        #altNotShownBody tr {
            display: table-row;
        }

        #altNotShownBody .toggleHide {
            display: none;
        }
    }
</style>
<partial name="_ApexCharts" />
<script src="~/js/eb-stats-chart.js" asp-append-version="true"></script>
<script>
    initEbStatsChart('@(ebStatsSuffix)', @Html.Raw(ebStatsJson));
</script>
