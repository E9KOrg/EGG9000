@using Discord.WebSocket;
@using static EGG9000.Common.Helpers.EggIncStatics;
@using EGG9000.Common.JsonData
@using EGG9000.Common.JsonData.EiStatics
@using EGG9000.Site.Controllers;
@using System.Globalization;
@using EGG9000.Common.Coops;
@using EGG9000.Common.Helpers.ArtifactImaging;
@inject DiscordSocketClient DiscordClient
@inject EGG9000.Site.Services.ArtifactImageRenderer ArtifactRenderer
@model (CustomBackup Backup, List<Contract> Contracts, List<Coop> Coops, DBUser user, List<DBCustomEgg> CustomEggs)

@{
    void rateRow(string label, double perSecond, string eggImg) {
        <div class="combo-rate">
            <span class="combo-rate-label">@label</span>
            <span class="combo-rate-primary">@((perSecond * 3600).ToEggString(true))<img class="combo-rate-egg" src="@eggImg" alt="egg" /><span class="combo-rate-per">per hour</span></span>
            <span class="combo-rate-alt">@((perSecond * 60).ToEggString(true))<img class="combo-rate-egg" src="@eggImg" alt="egg" /><span class="combo-rate-per">per min</span></span>
        </div>
    }

    async Task comboTile(string label, List<EggIncArtifactInstance> artifacts, double mineRate, double? coopRate, string eggImg, bool highlightBest, bool showOptimal = false) {
        <div class="combo-tile @(highlightBest ? "best" : "")">
            <div class="combo-tile-label">@Html.Raw(label)</div>
            <div class="combo-tile-body">
                <div class="combo-tile-set">
                    @{ await Html.RenderPartialAsync("-ArtifactSetImage", ArtifactRenderer.RenderSet(artifacts, highlightBest)); }
                </div>
                <div class="combo-tile-rates">
                    @{ rateRow("Mine", mineRate, eggImg); }
                    @if (coopRate is double cr) {
                        rateRow("Coop", cr, eggImg);
                    }
                </div>
                @if (showOptimal) {
                    <div class="combo-optimal">Artifacts are already optimal</div>
                }
            </div>
        </div>
    }

    List<EggIncArtifactInstance> Sort(List<EggIncArtifactInstance> current, List<EggIncArtifactInstance> toSort) {
        if (toSort is null) {
            return current;
        }
        var newList = new List<EggIncArtifactInstance>();
        foreach (var artifact in current) {
            var newArtifactIndex = toSort.FindIndex(x => x.Artifact.Equals(artifact.Artifact));
            if (newArtifactIndex >= 0) {
                newList.Add(toSort[newArtifactIndex]);
                toSort.RemoveAt(newArtifactIndex);
            } else {
                newList.Add(null);
            }
        }
        for (var i = 0; i < newList.Count; i++) {
            if (newList[i] is null) {
                newList[i] = toSort[0];
                toSort.RemoveAt(0);
            }
        }
        if (toSort.Count > 0) {
            newList.AddRange(toSort);
        }
        return newList;
    }

    (double myRate, double coopRate) GetChangedRate(CustomFarm farm, List<EggIncArtifactInstance> newArtifacts, Coop coop, CoopDetails coopDetails) {
        var newFarm = new CustomFarm {
                    CommonResearch = farm.CommonResearch,
                    Habs = farm.Habs,
                    TrainLength = farm.TrainLength,
                    NumChickens = farm.NumChickens,
                    EggType = farm.EggType,
                    Artifacts = newArtifacts,
                    Vehicles = farm.Vehicles
                };
        var stats = newFarm.WithStats(Model.Backup, coop, Model.CustomEggs, null, Model.Contracts.FirstOrDefault(x => x.ID == farm.ContractId));
        var currentTachyon = farm.Artifacts.FirstOrDefault(x => x.Boost == EggIncBoostTypeEnum.CoopMembersEggLayingRates)?.Value ?? 1;
        var newTachyon = newArtifacts.FirstOrDefault(x => x.Boost == EggIncBoostTypeEnum.CoopMembersEggLayingRates)?.Value ?? 1;
        var tachyonDifference = (newTachyon - 1) - (currentTachyon - 1) + 1;
        var coopNewRate = coopDetails is null ? stats.CurrentShippingRate : (coopDetails.CoopParticipants.Where(x => x.EggIncId != Model.Backup.EggIncId).Sum(x => x.Rate)) * tachyonDifference + stats.CurrentShippingRate;
        return (stats.CurrentShippingRate, coopNewRate);
    }
}
@{
    var farms = Model.Backup.Farms.Where(x => x.FarmType == Ei.FarmType.Contract && x.CoopSimulationEndTime == 0).ToList();
#if DEV9002
    // DEV9002 has no live coops, so the combos tab renders nothing (every farm hits coop is null and
    // continues). Whenever no farm maps to a real coop, render a fake card from whatever artifacts the
    // backup has so the new set-image layout is testable locally.
    var anyRenderable = farms.Any(f => Model.Coops.Any(c => c.Name.Equals(f.CoopId, StringComparison.OrdinalIgnoreCase)));
    if (!anyRenderable) {
        // Build a pool of real artifacts from the backup so each fake combo can be a genuine 4-slot set.
        <div class="card" style="margin-top:15px">
            <h4 class="card-header">Artifact Combos <span style="font-weight:normal;opacity:0.7;">(DEV9002 fake data)</span></h4>
            <div class="card-body">
                <ul>
                    <li>These are the best artifact combos for each farm with the current chicken population</li>
                    <li>Won't change your Gusset</li>
                    <li>Doesn't verify other co-op members have the shipping capacity yet</li>
                </ul>
            </div>
        </div>
        <div class="flex afx-card-container">
            @for (var fake = 0; fake < 2; fake++) {
                <div class="card">
                    <h4 class="card-header"><img class="ei-egg" src="/images/Egg_1.png" alt="Egg" /> The Big One (Fake @(fake + 1))</h4>
                    @{
                        // Candidate 0 = current. Fake 1: current is beaten by a suggestion (distinct sets).
                        // Fake 2: current is the best, so the winning suggestion recommends the current set
                        // itself (same artifacts, same rate) and Current reads "already optimal".
                        var fakeCurrentCoop = fake == 0 ? 540e12 / 60 : 800e12 / 60;
                        // Per-variant coop rates: current, woStones (No/With Deflector), wStones (No/With).
                        var rNoDefl = 633e12 / 60;
                        var rWithDefl = fake == 0 ? 703e12 / 60 : fakeCurrentCoop; // Fake 2 winner == current rate
                        var rNoDeflS = 650e12 / 60;
                        var rWithDeflS = 690e12 / 60;
                        var fakeCoop = new List<double> { fakeCurrentCoop, rNoDefl, rWithDefl, rNoDeflS, rWithDeflS };
                        var fakeBest = EGG9000.Site.Services.ArtifactImageRenderer.BestSetIndex(fakeCoop);
                        var fakeOptimal = fakeBest == 0;
                        // All sets come from the module helper, which enforces one-artifact-per-family. The
                        // offset just makes the variants look distinct. Current is a deflector build; Fake 2's
                        // winning "With Deflector" suggestion equals it.
                        var bs = EGG9000.Common.Helpers.ArtifactHelpers.BuildSampleSet;
                        var setCurrent = bs(Model.Backup, true, 0);
                        var setNoDefl = bs(Model.Backup, false, 0);
                        var setWithDefl = fakeOptimal ? setCurrent : bs(Model.Backup, true, 1);
                        var setNoDeflS = bs(Model.Backup, false, 1);
                        var setWithDeflS = bs(Model.Backup, true, 2);
                    }
                    <div class="card-body combo-body">
                        @{
                            var fakeEgg = "/images/Egg_1.png";
                            await comboTile("Current", setCurrent, 216e12 / 60, fakeCurrentCoop, fakeEgg, fakeOptimal, fakeOptimal);
                        }
                        <div class="combo-section">Without changing stones</div>
                        <div class="combo-grid">
                            @{
                                await comboTile("No Deflector", setNoDefl, 228e12 / 60, rNoDefl, fakeEgg, fakeBest == 1);
                                await comboTile("With Deflector", setWithDefl, 216e12 / 60, rWithDefl, fakeEgg, fakeBest == 2);
                            }
                        </div>
                        <div class="combo-section">If you change stones</div>
                        <div class="combo-grid">
                            @{
                                await comboTile("No Deflector", setNoDeflS, 228e12 / 60, rNoDeflS, fakeEgg, fakeBest == 3);
                                await comboTile("With Deflector", setWithDeflS, 216e12 / 60, rWithDeflS, fakeEgg, fakeBest == 4);
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
        return;
    }
#endif
    if (farms.Count == 0) {
        <div class="card" style="margin-top:15px">
            <h4 class="card-header">ℹNo Active Contracts</h4>
            <div class="card-body">
                You are not currently participating in any contracts. When you do, suggested artifact combinations to maximize your co-op rates will appear here.
            </div>
        </div>
    } else {
        <div class="card" style="margin-top:15px">
            <h4 class="card-header">Artifact Combos</h4>
            <div class="card-body">
                <ul>
                    <li>These are the best artifact combos for each farm with the current chicken population</li>
                    <li>Won't change your Gusset</li>
                    <li>Doesn't verify other co-op members have the shipping capacity yet</li>
                </ul>
            </div>
        </div>
        <div class="flex afx-card-container">
            @foreach (var farm in farms) {
                var coop = Model.Coops.FirstOrDefault(x => x.Name.Equals(farm.CoopId, StringComparison.OrdinalIgnoreCase));
                var isHome = farm.FarmType == Ei.FarmType.Home;

                var contract = Model.Contracts.FirstOrDefault(x => x.ID == farm.ContractId);
                var farmStats = farm.WithStats(Model.Backup, coop, Model.CustomEggs, null, contract);
                if (coop is null) {
                    continue;
                }
                var usersWithBackups = isHome ? new List<UserWithBackup>() : coop.UserCoopsXrefs.SelectMany(x => x.User.EggIncAccounts.Select(y => new UserWithBackup { Account = y, Backup = y.Backup, User = x.User })).ToList();
                var coopDetails = isHome ? null : new CoopDetails(coop, coop.Contract, coop.League, usersWithBackups, Model.CustomEggs, DiscordClient, coop.LastStatusUpdate);
                var currentCoopRate = isHome ? 0 : coopDetails.CoopParticipants.Sum(x => x.Rate);

                var bestWithoutTachyon = Sort(farm.Artifacts, ArtifactCombos.FindBestCombo(Model.Backup, farm, coop, false, false, Model.CustomEggs, null));
                var withoutTachyon = GetChangedRate(farm, bestWithoutTachyon, coop, coopDetails);
                var bestWithTachyon = Sort(farm.Artifacts, ArtifactCombos.FindBestCombo(Model.Backup, farm, coop, true, false, Model.CustomEggs, null));
                var withTachyon = GetChangedRate(farm, bestWithTachyon, coop, coopDetails);

                var bestWithoutTachyonS = Sort(farm.Artifacts, ArtifactCombos.FindBestCombo(Model.Backup, farm, coop, false, true, Model.CustomEggs, null));
                var withoutTachyonS = GetChangedRate(farm, bestWithoutTachyonS, coop, coopDetails);
                var bestWithTachyonS = Sort(farm.Artifacts, ArtifactCombos.FindBestCombo(Model.Backup, farm, coop, true, true, Model.CustomEggs, null));
                var withTachyonS = GetChangedRate(farm, bestWithTachyonS, coop, coopDetails);

                <div class="card">
                    @if (isHome) {
                        <h4 class="card-header"><img class="ei-egg" src="/images/Egg_@((int)farm.EggType).png" alt="Egg" /> Home Farm</h4>
                    } else {
                        <h4 class="card-header"><img class="ei-egg" src="@(EggIncStatics.GetEggByContract(contract, Model.CustomEggs).image)" alt="Egg" /> @Model.Contracts.FirstOrDefault(x => x.ID == farm.ContractId)?.Name</h4>
                    }

                    @{
                        var eggImg = isHome ? $"/images/Egg_{(int)farm.EggType}.png" : EggIncStatics.GetEggByContract(contract, Model.CustomEggs).image;
                        // Candidate 0 is the CURRENT set; suggestions follow. Ask the renderer which wins
                        // (ties favour index 0). If current wins, it is already optimal and no suggestion
                        // is highlighted. Compared on coop rate, or mine rate for the home farm.
                        var currentRate = isHome ? farmStats.CurrentShippingRate : currentCoopRate;
                        var candidateRates = isHome
                            ? new List<double> { currentRate, withoutTachyon.myRate, withoutTachyonS.myRate }
                            : new List<double> { currentRate, withoutTachyon.coopRate, withTachyon.coopRate, withoutTachyonS.coopRate, withTachyonS.coopRate };
                        var bestIndex = EGG9000.Site.Services.ArtifactImageRenderer.BestSetIndex(candidateRates);
                        var currentOptimal = bestIndex == 0;
                    }
                    <div class="card-body combo-body">
                        @{
                            await comboTile("Current", farm.Artifacts,
                                farmStats.CurrentShippingRate,
                                isHome ? (double?)null : currentCoopRate, eggImg, currentOptimal, currentOptimal);
                        }
                        <div class="combo-section">Without changing stones</div>
                        <div class="combo-grid">
                            @{
                                await comboTile(isHome ? "Suggested" : "No Deflector", bestWithoutTachyon,
                                    withoutTachyon.myRate,
                                    isHome ? (double?)null : withoutTachyon.coopRate,
                                    eggImg, bestIndex == 1);
                                if (!isHome) {
                                    await comboTile("With Deflector", bestWithTachyon,
                                        withTachyon.myRate,
                                        withTachyon.coopRate,
                                        eggImg, bestIndex == 2);
                                }
                            }
                        </div>
                        <div class="combo-section">If you change stones</div>
                        <div class="combo-grid">
                            @{
                                await comboTile(isHome ? "Suggested" : "No Deflector", bestWithoutTachyonS,
                                    withoutTachyonS.myRate,
                                    isHome ? (double?)null : withoutTachyonS.coopRate,
                                    eggImg, isHome ? bestIndex == 2 : bestIndex == 3);
                                if (!isHome) {
                                    await comboTile("With Deflector", bestWithTachyonS,
                                        withTachyonS.myRate,
                                        withTachyonS.coopRate,
                                        eggImg, bestIndex == 4);
                                }
                            }
                        </div>
                    </div>

                </div>

            }
        </div>

    }
}

<style>
    .card {
        margin-bottom: 15px;
    }

    /* Farm cards flow two-up when there's room. */
    .flex {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        gap: 15px;
    }

        .flex > div {
            flex: 1 1 calc(50% - 15px);
            min-width: 340px;
        }

</style>