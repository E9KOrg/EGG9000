@model List<LeaderboardUser>
@inject Discord.WebSocket.DiscordSocketClient discord
@{
	ViewData["Title"] = "Leaderboard";

	var claimsIdentity = (System.Security.Claims.ClaimsIdentity)User.Identity;
	var discordId = claimsIdentity.Claims.First(x => x.Type == "DiscordId").Value;

	var myAccounts = Model.Where(x => x.DisplayDiscordId.ToString() == discordId);
	// Read/staff tier - gates only the clickable player-name link to MyFarms on this read-only page.
	var isAdmin = User.IsInRole("Admin") || User.IsInRole("GuildAdmin") || User.IsInRole("GuildLesserAdmin") || User.IsInRole("GuildReadOnlyAdmin");
}


@if (myAccounts.Count() == 1) {
	<a class="btn btn-secondary" href="#@myAccounts.First().Backup.EggIncId">Jump to me</a>
} else if (myAccounts.Count() > 1) {
	foreach (var account in myAccounts) {
		<a class="btn btn-secondary" href="#@account.Backup.EggIncId">Jump to @account.Backup.UserName</a>
	}
}
<style>
	th {
		position: sticky;
		top: 0;
		text-align: center !important;
	}

	a img, th img, td img {
		height: 20px;
	}

	table {
		width: auto !important;
	}

	@@media (min-width: 1024px) {
		th, td {
			padding-left: 10px !important;
			padding-right:10px  !important;
		}
	}

	.Me td {
		background-color: #adffaa !important;
	}

	.bootstrap-dark .Me td {
		background-color: #2c462b !important;
	}

	.monospace {
		font-size: 0;
		white-space: nowrap;
	}

		.monospace span {
			width: 0.53em;
			font-size: 1rem;
			display: inline-block;
			text-align: center;
		}

			.monospace span.period {
				width: auto;
			}
</style>
Sort By:
<a class="btn btn-primary" href="?sortby=se"><img src="~/images/Egg_soul.png" /></a>
<a class="btn btn-primary" href="?sortby=pe"><img src="~/images/Egg_of_Prophecy.png" /></a>
<a class="btn btn-primary" href="?sortby=start">First Contract</a>
<a class="btn btn-primary" href="?sortby=permit">Permit</a>
