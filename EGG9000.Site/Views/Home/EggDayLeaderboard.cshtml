@using static EGG9000.Site.Controllers.HomeController;
@model List<EggDayResults>
@inject Discord.WebSocket.DiscordSocketClient discord
@{
	ViewData["Title"] = "Leaderboard";

	var claimsIdentity = (System.Security.Claims.ClaimsIdentity)User.Identity;
	var discordId = claimsIdentity.Claims.First(x => x.Type == "DiscordId").Value;

	var myAccounts = Model.Where(x => x.UserAccount.User.DiscordId.ToString() == discordId);
	var isAdmin = User.IsInRole("Admin") || User.IsInRole("GuildAdmin");
}

@if (myAccounts.Count() == 1) {
	<a class="btn btn-secondary" href="#@myAccounts.First().UserAccount.Account.Id">Jump to me</a>
} else if (myAccounts.Count() > 1) {
	foreach (var account in myAccounts) {
		<a class="btn btn-secondary" href="#@account.UserAccount.Account.Id">Jump to @(account.UserAccount.Account.Backup?.UserName ?? account.UserAccount.Account.Name)</a>
	}
}
<style>
	th {
		position: sticky;
		top: 0;
		text-align: center;
	}

		th img, td img {
			height: 20px;
		}

	table {
		width: auto !important;
	}



	.Me td {
		background-color: #adffaa !important;
	}

	.bootstrap-dark .Me td {
		background-color: #2c462b !important;
	}

	.monospace {
		font-size: 0;
		white-space: nowrap;
	}

		.monospace span {
			width: 0.53em;
			font-size: 1rem;
			display: inline-block;
			text-align: center;
		}

			.monospace span.period {
				width: auto;
			}
</style>
<div>
	Year Selector<br />
	@foreach(var year in ViewBag.years) {
		if(ViewBag.year == year) {
			<a href="?sortby=@(ViewBag.sortby)&prefix=@(ViewBag.prefix)&year=@(year)"><button disabled class="btn btn-secondary disabled">@year</button></a>
		} else {
			<a href="?sortby=@(ViewBag.sortby)&prefix=@(ViewBag.prefix)&year=@(year)"><button class="btn btn-primary">@year</button></a>
		}
	}
</div>
<br />
<div>
	Sort by<br />
	<a href="?sortby=eb&prefix=@(ViewBag.prefix)&year=@(ViewBag.year)"><button disabled="@(ViewBag.sortby == "eb")" class="btn @(ViewBag.sortby == "eb" ? "btn-secondary disabled" : "btn-primary")">EB Gain</button></a>
	<a href="?sortby=se&prefix=@(ViewBag.prefix)&year=@(ViewBag.year)"><button disabled="@(ViewBag.sortby == "se")" class="btn @(ViewBag.sortby == "se" ? "btn-secondary disabled" : "btn-primary")">SE Gain</button></a>
	<a href="?sortby=seper&prefix=@(ViewBag.prefix)&year=@(ViewBag.year)"><button disabled="@(ViewBag.sortby == "seper")" class="btn @(ViewBag.sortby == "seper" ? "btn-secondary disabled" : "btn-primary")">% Gain</button></a>
	<a href="?sortby=prestige&prefix=@(ViewBag.prefix)&year=@(ViewBag.year)"><button disabled="@(ViewBag.sortby == "prestige")" class="btn @(ViewBag.sortby == "prestige" ? "btn-secondary disabled" : "btn-primary")">Prestiges</button></a>
	@if (ViewBag?.sortby != null && ViewBag?.sortby != "") {
		<a href="?prefix=@(ViewBag.prefix)&year=@(ViewBag.year)"><button class="btn btn-danger">Clear</button></a>
	}
</div>
<br />
<div>
	Filter by<br />
	@foreach(var prefix in SIPrefix.Prefixes) {
		<a href="?sortby=@(ViewBag.sortby)&prefix=@(prefix.Base)&year=@(ViewBag.year)"><button disabled="@(ViewBag.prefix == prefix.Base)" class="btn @(ViewBag.prefix == prefix.Base ? "btn-secondary disabled" : "btn-primary")">@prefix.Name.Titleize()</button></a>
	}
	@if (ViewBag.prefix != null && ViewBag?.prefix != 0) {
		<a href="?sortby=@(ViewBag.sortby)&year=@(ViewBag.year)"><button class="btn btn-danger">Clear</button></a>
	}
</div>
<br />
<div class="row">
	<div class="col">
		<table class="table table-striped table-sm">
			<thead>
				<tr>
					<th></th>
					<th style="text-align: left;">Name</th>
					<th>EB Gain</th>
					<th>SE Gain</th>
					<th>% Gain</th>
					<th>Prestiges</th>
				</tr>
			</thead>
			<tbody>
				@{
					var i = 0;
					foreach (var account in Model.Where(x => x.EBGain > 0 && x.PrestigeCount > 0)) {
						i++;
						RowTemplate(account, i);
					}
				}
			</tbody>
		</table>

	</div>
</div>

@{
	void RowTemplate(EggDayResults account, int i) {
		var isMe = account.UserAccount.User.DiscordId.ToString() == discordId;
		
		var ebrgx = new Regex(@"\(.+?\)");
		var name = ebrgx.Replace(account.UserAccount.User.DiscordUsername, "").Trim();


		<tr id="@account.UserAccount.Account.Id" class="@(isMe ? "Me" : "")">

			<td align="right"> @i </td>

			<td style="max-width: 150px; text-overflow: ellipsis; line-break: strict;">
				@if (isMe) {
					<div id="@account.UserAccount.Account.Id" style="position: relative; top: -40px;"></div>
				}
				@name
			</td>
			<td>
				@account.EBGain.ToEggString()
			</td>
			<td>
				@account.SEGain.ToEggString()
			</td>
			<td>
				@account.SEGainPercent.ToString("P0")
			</td>
			<td>@account.PrestigeCount</td>
		</tr>
	}
}
