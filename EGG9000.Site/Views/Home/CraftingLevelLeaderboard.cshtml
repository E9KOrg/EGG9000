@using static EGG9000.Common.Helpers.Prefarm;
@model List<LeaderboardUser>
@inject Discord.WebSocket.DiscordSocketClient discord
@{
    ViewData["Title"] = "Crafting XP Leaderboard";

    var claimsIdentity = (System.Security.Claims.ClaimsIdentity)User.Identity;
    var discordId = claimsIdentity.Claims.First(x => x.Type == "DiscordId").Value;

    var myAccounts = Model.Where(x => x.DiscordUser.Id.ToString() == discordId);
    var isAdmin = User.IsInRole("Admin") || User.IsInRole("GuildAdmin");
}

@if (myAccounts.Count() == 1)
{
    <a class="btn btn-secondary" href="#@myAccounts.First().Backup.EggIncId">Jump to me</a>
}
else if (myAccounts.Count() > 1)
{
    foreach (var account in myAccounts)
    {
        <a class="btn btn-secondary" href="#@account.Backup.EggIncId">Jump to @account.Backup.UserName</a>
    }
}
<style>
    th {
        position: sticky;
        top: 0;
        text-align: center;
    }

        th img, td img {
            height: 20px;
        }

    table {
        width: auto !important;
    }

    .Me td {
        background-color: #adffaa !important;
    }

    .bootstrap-dark .Me td {
        background-color: #2c462b !important;
    }

    .monospace {
        font-size: 0;
        white-space: nowrap;
    }

        .monospace span {
            width: 0.53em;
            font-size: 1rem;
            display: inline-block;
            text-align: center;
        }

            .monospace span.period {
                width: auto;
            }
</style>
<div class="row">
    <div class="col">
        <table class="table table-striped table-sm">
            <thead>
                <tr>
                    <th></th>
                    <th style="text-align: left;">Name</th>
                    <th>Crafting Level</th>
                    <th>Crafting XP</th>
                </tr>
            </thead>
            <tbody>
                @{
                    var i = 0;
                    foreach (var account in Model)
                    {
                        i++;
                        RowTemplate(account, i);
                    }
                }
            </tbody>
        </table>

    </div>
</div>

@{
    string CommaSeparate(double score)
    {
        return string.Format("{0:N0}", score);
    }
    void RowTemplate(LeaderboardUser account, int i)
    {
        var isMe = account.DiscordUser.Id.ToString() == discordId;
        <tr id="@account.User.DiscordId" class="@(isMe ? "Me" : "")">

            <td align="right"> @i </td>

            <td style="max-width: 150px; text-overflow: ellipsis; line-break: strict;">
                @if (isMe)
                {
                    <div id="@account.Backup.EggIncId" style="position: relative; top: -40px;"></div>
                }
                @if (isAdmin)
                {
                    <a href="/Home/ViewUser/@(account.User.Id)">
                        @account.DiscordUser.GetCleanName()
                    </a>
                }
                else if (isMe)
                {
                    <a href="/MyFarms">
                        @account.DiscordUser.GetCleanName()
                    </a>
                }
                else
                {
                    @account.DiscordUser.GetCleanName()
                }
            </td>

            <td align="right" style="padding-left: 20px; padding-right: 10px;">
                @CommaSeparate(account.Backup.GetCraftingLevel())
            </td>
            <td align="right" style="padding-right: 20px; padding-left: 10px;">
                @CommaSeparate(account.Backup.CraftingXP)
            </td>
        </tr>
    }
}