@model List<LeaderboardUser>
@using EGG9000.Bot;
@using EGG9000.Common;

@inject Discord.WebSocket.DiscordSocketClient discord
@{
    ViewData["Title"] = "Comparison";
    List<Tuple<double, string>> myEb = ViewBag.MyEbs;
    List<Tuple<double, string>> listOfEb = ViewBag.ListOfEb;
    List<string> allRoles = ViewBag.AllRoles;
    List<string> myNames = ViewBag.MyNames;
}

<h1>EB Comparison</h1>
<hr />

<div class="row">
    <div class="col-md-4 mt-3">
        <div class="card">
            <div class="card-header"><b>@(myEb.Count > 1 ? "Your EBs" : "Your EB")</b></div>
            <div class="card-body">
                <table class="table table-sm">
                    <tbody>
                        @foreach (var eb in myEb)
                        {
                            <tr>
                                <td>@myNames[myEb.IndexOf(eb)]</td>
                                <td>@ArgumentsHelper.NumberToString(eb.Item1,true,2)</td>
                                <td>@eb.Item2</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-8 mt-3">
        <div class="card">
            <div class="card-header"><b>Server Stats</b></div>
            <div class="card-body">
                <table class="table table-sm">
                    <tbody>
                        <tr>
                            <td>Highest Eb:</td>
                            <td>@ArgumentsHelper.NumberToString((listOfEb.Select(o => o.Item1).Max()),true,2)</td>
                            <td>@SIPrefix.GetPrefixFromEB(listOfEb.Select(o => o.Item1).Max()).RankWithSubRank</td>
                        </tr>
                        <tr>
                            <td>Average Eb:</td>
                            <td>@ArgumentsHelper.NumberToString(listOfEb.Select(o => o.Item1).Average(),true,2)</td>
                            <td>@SIPrefix.GetPrefixFromEB(listOfEb.Select(o => o.Item1).Average()).RankWithSubRank</td>
                        </tr>
                        <tr>
                            <td>Median Eb:</td>
                            <td>
                                @{
                                    var medianEb = listOfEb.Select(o => o.Item1).OrderByDescending(o => o).ToList()[listOfEb.Select(o => o.Item1).ToList().Count() / 2];
                                }
                                @ArgumentsHelper.NumberToString(medianEb,true,2)
                            </td>
                            <td>@SIPrefix.GetPrefixFromEB(medianEb).RankWithSubRank</td>
                        </tr>
                        <tr>
                            <td>Combined Server Eb:</td>
                            <td>@ArgumentsHelper.NumberToString(listOfEb.Select(o => o.Item1).Sum(),true,2)</td>
                            <td>@SIPrefix.GetPrefixFromEB(listOfEb.Select(o => o.Item1).Sum()).RankWithSubRank</td>
                        </tr>
                    </tbody>
                </table>
                 
            </div>
        </div>
    </div>
</div>
<div class="mt-3 card">
    <h4 class="card-header">Server EB Distribution</h4>
    <div class="card-body">
        <div id="chartEb"></div>
    </div>
</div>

<partial name="_ApexCharts" />
<script>
var ebOptions = {
    series: [{
        data: [
            @foreach (var r in allRoles)
            {
                if (listOfEb.Count(o => o.Item2 == r) != 0)
                {
                    @Html.Raw($"{listOfEb.Count(o => o.Item2 == r)},")
                }
            }
        ]
    }],
    theme: {
        mode: getCookie('Egg9000Theme') == 'bootstrap-dark' ? 'dark' : 'light'
    },
    annotations: {
        points: [
            @foreach (var eb in myEb)
            {
            @:{
            @:  x: '@eb.Item2',
            @:  seriesIndex: 0,
            @:  label: {
            @:      borderColor: '#775DD0',
            @:      offsetY: 0,
            @:      style: {
            @:          color: '#fff',
            @:          background: '#775DD0',
            @:      },
            @:      text: '@((myEb.Count > 1 ? (myNames[myEb.IndexOf(eb)]) + " is" : "You are" )) @("aeiouAEIOU".IndexOf(eb.Item2.Substring(0,1)) >= 0 ? "an" : "a") @eb.Item2',
            @:  }
            @:},
            }
            ]
        },
        chart: {
            height: 350,
            type: 'bar',
            events: {
                click: function(chart, w, e) {
                    // console.log(chart, w, e)
                }
            }
        },
        plotOptions: {
            bar: {
                distributed: true,
            }
        },
        dataLabels: {
            enabled: false
        },
        legend: {
            show: false
        },
        xaxis: {
            categories: [
                @foreach (var r in allRoles)
                {
                    if (listOfEb.Count(o => o.Item2 == r) != 0)
                    {
                        @Html.Raw($"'{r}',")
                    }
                }
            ],
            labels: {
                style: {
                    fontSize: '12px'
                }
            }
        },
        tooltip: {
    y: {
      formatter: function(val) {
        return val
      },
      title: {
        formatter: function (seriesName) {
          return ''
        }
      }
    }
  }
    };
    var ebChart = new ApexCharts(document.querySelector("#chartEb"), ebOptions);
    ebChart.render();
</script>