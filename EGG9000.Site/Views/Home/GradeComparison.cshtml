@model List<LeaderboardUser>
@using EGG9000.Bot;
@using EGG9000.Common;

@inject Discord.WebSocket.DiscordSocketClient discord
@{
    ViewData["Title"] = "Grade/CS Comparison";
    List<Tuple<int, double>> myGrades = ViewBag.MyGradeData;
    List<string> myNames = ViewBag.MyNames;
    List<Tuple<int, double>> allGradeData = ViewBag.AllGradeData;
    List<int> allGrades = ViewBag.AllGrades;
}

<h1>Grade/CS Comparison</h1>
<hr />

<div class="row">
    <div class="col-md-4 mt-3">
        <div class="card">
            <div class="card-header"><b>@(myGrades.Count > 1 ? "Your Grades/Total CS Scores" : "Your Grade/Total CS Score")</b></div>
            <div class="card-body">
                <table class="table table-sm">
                    <tbody>
                        @foreach (var grade in myGrades)
                        {
                            <tr>
                                <td>@myNames[myGrades.IndexOf(grade)] <img style="max-height: 23px;" src="@PlayerGradeDetails.GetImage((uint)grade.Item1)" alt="@PlayerGradeDetails.GetText((Ei.Contract.Types.PlayerGrade)grade.Item1)" /></td>
                                <td>@($"{grade.Item2:n0}")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-8 mt-3">
        <div class="card">
            <div class="card-header"><b>Server CS Stats</b></div>
            <div class="card-body">
                <table class="table table-sm">
                    <tbody>
                        <tr>
                            <td>Highest Total CS:</td>
                            <td>@($"{allGradeData.Select(o => o.Item2).Max():n0}")</td>
                        </tr>
                        <tr>
                            <td>Average Total CS:</td>
                            <td>@($"{allGradeData.Select(o => o.Item2).Average():n0}")</td>
                        </tr>
                        <tr>
                            <td>Median Total CS:</td>
                            <td>@($"{allGradeData.Select(o => o.Item2).OrderByDescending(o => o).ToList()[allGradeData.Select(o => o.Item2).ToList().Count() / 2]:n0}")</td>
                        </tr>
                        <tr>
                            <td>Combined Server Total CS:</td>
                            <td>@($"{allGradeData.Select(o => o.Item2).Sum():n0}")</td>
                        </tr>
                    </tbody>
                </table>

            </div>
        </div>
    </div>
</div>
<div class="mt-3 card">
    <h4 class="card-header">Server Grade Distribution</h4>
    <div class="card-body">
        <div id="chartGrade"></div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    var ebOptions = {
        series: [{
            data: [
                @foreach (var g in allGrades) {
                    if (allGradeData.Count(o => o.Item1 == g) != 0) {
                        @Html.Raw($"{allGradeData.Count(o => o.Item1 == g)},")
                    }
                }
            ]
        }],
        theme: {
            mode: getCookie('Egg9000Theme') == 'bootstrap-dark' ? 'dark' : 'light'
        },
        annotations: {
            points: [
                @foreach (var grade in myGrades){
                    @:{
                    @:x: '@PlayerGradeDetails.GetNameFromLeague((uint)grade.Item1)',
                    @:seriesIndex: 0,
                    @:label: {
                    @:borderColor: '#775DD0',
                    @:offsetY: 0,
                    @:style: {
                    @:color: '#fff',
                    @:background: '#775DD0',
                    @:      },
                    @:text: '@((myGrades.Count > 1 ? String.Join(",", (myNames.Where(m => myGrades[myNames.IndexOf(m)].Item1 == grade.Item1))) + (myGrades.Count(g => g.Item1 == grade.Item1) > 1 ? " are" : " is") : "You are")) Grade @PlayerGradeDetails.GetNameFromLeague((uint)grade.Item1)',
                    @:  }
                    @:},
                }
            ]
        },
        chart: {
            height: 350,
            type: 'bar',
        },
        plotOptions: {
            bar: {
                distributed: true,
            }
        },
        dataLabels: {
            enabled: false
        },
        legend: {
            show: false
        },
        xaxis: {
            categories: [
                @foreach (var g in allGrades)
                {
                    if (allGradeData.Count(o => o.Item1 == g) != 0)
                    {
                        @Html.Raw($"'{PlayerGradeDetails.GetNameFromLeague((uint)g)}',")
                    }
                }
            ],
            labels: {
                style: {
                    fontSize: '12px'
                }
            }
        },
        tooltip: {
            y: {
                formatter: function(val) {
                    return val
                },
                title: {
                    formatter: function (seriesName) {
                        return ''
                    }
                }
            }
        }
    };
    var gradeChart = new ApexCharts(document.querySelector("#chartGrade"), ebOptions);
    gradeChart.render();
</script>