@model (List<EGG9000.Common.Database.Entities.GuildContract> Contracts, Guild DbGuild )
@{
    ViewData["Title"] = "Contracts";
    var isAdmin = User.IsInRole("Admin") || User.IsInRole("GuildAdmin") || User.IsInRole("GuildLesserAdmin");
}

@if (isAdmin || (Model.DbGuild?.PublicScoreGrid ?? false))
{
    <a href="/Contract/RecentScoresGrid" class="btn btn-primary">Recent Scores Grid</a>
}
<h2>Recent Contracts</h2>
@foreach (var contractGroup in Model.Contracts.OrderBy(x => x.DeletedChannel).Where(x => x.Created > DateTimeOffset.FromUnixTimeSeconds(1682917200)).GroupBy(x => x.Contract))
{
    var contract = contractGroup.Key;
    <div class="card">
        <h5 class="card-header">
            @if (contract.cc_only)
            {
                <a><img title="Subscriber-Only Contract" alt="Subcriber-Only Contract" src="https://cdn.discordapp.com/emojis/1131045418319495369.webp" style="width: 30px; height: auto"></a>
            }
            @contract.Name
            @if (contract.GoodUntil < DateTimeOffset.Now)
            {
                <i class="text-danger">Expired</i>
            } else
            {
                <i class="text-info">Expires in @FormatTime(contract.GoodUntil - DateTimeOffset.Now)</i>
            }
        </h5>
        <div class="card-body">
            @foreach (var grade in (Ei.Contract.Types.PlayerGrade[])Enum.GetValues(typeof(Ei.Contract.Types.PlayerGrade)))
            {
                if (grade == Ei.Contract.Types.PlayerGrade.GradeUnset)
                {
                    continue;
                }
                <a href="/Contract/Details?GuildId=@contractGroup.First().GuildID&ContractId=@contractGroup.First().ContractID&League=@((int)grade)" class="btn btn-primary">@PlayerGradeDetails.GetNameFromLeague((int)grade) Co-ops</a>
            }
            @if (isAdmin)
            {
                <a href="/Contract/Day1CoopsFillLate?GuildId=@contractGroup.First().GuildID&ContractId=@(contract.ID)">Day 1 Co-ops</a>
            }
            @if (contractGroup.Any(x => x.HasScores))
            {
                <a href="/Contract/ScoreGraph?GuildId=@contractGroup.First().GuildID&ContractId=@contractGroup.First().ContractID" class="btn btn-primary">Scores Graph</a>
            }
        </div>
    </div>
    <br />
}

@functions {
        public static string FormatTime(TimeSpan time)
        {
            if (time.TotalMinutes < 1) return "Soon";
            else if (time.TotalHours < 1) return $"{(int)time.TotalMinutes}m";
            else if (time.TotalDays < 1) return $"{(int)time.TotalHours}h{(int)time.Minutes}m";
            else return $"{(int)time.TotalDays}d{(int)time.Hours}h{(int)time.Minutes}m";
        }
}