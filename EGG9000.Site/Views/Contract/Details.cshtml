 @using static EGG9000.Common.Helpers.Prefarm
@using Discord.WebSocket
@using EGG9000.Common.EggIncAPI
@model EGG9000.Site.Controllers.ContractController.CoopsViewModel
@{
    ViewData["Title"] = "Coops - " + Model.GuildContract.Contract.Name;
    var targetAmount = Model.GuildContract.Contract.Details.GradeSpecs[(int)Model.League - 1].Goals.Last().TargetAmount;

    DiscordSocketClient discord = ViewBag.Discord;

    var alienBackups = new List<UserPreFarm>();
    var currentCoops = Model.CoopsBreakdown.ExistingCoops.OrderBy(x => x.Coop.Finished).ThenByDescending(x => x.HasSpots).ThenBy(x => x.TimeRemaining).ToList();

    var guildContract = Model.GuildContract;
    var guild = discord.Guilds.First(x => x.Id == Model.GuildContract.GuildID);
    var claimsIdentity = (System.Security.Claims.ClaimsIdentity)User.Identity;
    var discordId = claimsIdentity.Claims.First(x => x.Type == "DiscordId").Value;

    var count = currentCoops.Count;
    var ebrgx = new Regex(@"\(.+?\)");
    // Two staff tiers gate this page. isAdmin = write tier (remove users from coops) - global Admins,
    // guild admins, and GuildLesserAdmin (FH/CC staff). isStaff = read tier - everyone in isAdmin plus
    // GuildReadOnlyAdmin, the read-only CT learners who get coop names, thread links and the spots panel
    // but no write controls. Member discord/egg ids and the X button stay on isAdmin.
    var isAdmin = User.IsInRole("Admin") || User.IsInRole("GuildAdmin") || User.IsInRole("GuildLesserAdmin");
    var isStaff = isAdmin || User.IsInRole("GuildReadOnlyAdmin");

    var activeCoops = currentCoops.Select(c => new {
        Name = (isStaff || c.CoopParticipants.Any(u => u.DiscordUser?.Id.ToString() == discordId)) ? c.Coop.Name : "",
        c.Coop.ContractID,
        CurrentCoop = c.CoopParticipants.Any(x => x.DiscordUser?.Id.ToString() == discordId),
        Status = c.Coop.Finished ? "Finished" : c.TimeRemaining < TimeSpan.Zero ? "Complete once everyone checks in" : $"Time to complete {c.TimeRemaining.Humanize(precision: 2).ShortenTime()}",
        Users = c.CoopParticipants.OrderByDescending(x => x.Projected).Select(u => new {
            Name = (u.DiscordUser?.Roles.Any(r => r.Id == 796512753241161748) ?? false ? "🆕" : "") + ebrgx.Replace(u.Name, ""),
            NumChickens = u.NumChickens.ToEggString(),
            Rate = $"{ArgumentsHelper.NumberToString(u.Rate * 60 * 60, false)}/h",
            Projected = u.Projected.ToEggString(),
            Status = u.DBUser is null ? "👽" : u.InCoop ? "✔️" : "❌",
            Locked = true,
            EggIncId = (isAdmin || u.DiscordUser?.Id.ToString() == discordId) ? u.EggIncId : "",
            UserId = (isAdmin || u.DiscordUser?.Id.ToString() == discordId) ? u.DBUser?.Id : Guid.Empty,
            DiscordID = (isAdmin || u.DiscordUser?.Id.ToString() == discordId) ? u.DiscordUser?.Id : 0,
            Guild = u.Account?.Guild
        }),
        MaxSize = Model.GuildContract.Contract.Details.MaxCoopSize,
        Rate = $"{ArgumentsHelper.NumberToString(c.CoopParticipants.Sum(x => x.Rate) * 60 * 60, false)}/h",
        Percent = (c.CoopParticipants.Sum(x => x.Projected) / targetAmount).ToString("P0"),
        CoopId = (isAdmin || c.CoopParticipants.Any(u => u.DiscordUser?.Id.ToString() == discordId)) ? c.Coop.Id : Guid.Empty,
        HoursToFinish = c.TimeRemaining.TotalHours,
        DiscordChannelId = (c.Coop.ThreadID != 0 ? c.Coop.ThreadID.ToString() : c.Coop.DiscordChannelId.ToString()),
        DeletedChannel = (c.Coop.ThreadID != 0 ? c.Coop.ThreadArchived : c.Coop.DeletedChannel),
        OverflowGuildId = c.Coop.OverflowGuildId.ToString()
    });

    var isSolo = Model.GuildContract.Contract.MaxUsers <= 1;

    if(isSolo) {
        Model.CoopsBreakdown.PotentialCoops = new List<CoopDetails> {
            new CoopDetails(Model.CoopsBreakdown.PotentialCoops.SelectMany(c => c.CoopParticipants).ToList(), guildContract, Model.League)
        };
    }

    var potentialCoops = Model.CoopsBreakdown.PotentialCoops.Select(c => {
        var users = c.CoopParticipants.OrderByDescending(x => x.Projected).Select(u => new {
            EggIncId = (isAdmin || u.DiscordUser?.Id.ToString() == discordId) ? u.EggIncId : "",
            DatabaseId = (isAdmin || u.DiscordUser?.Id.ToString() == discordId) ? u.DBUser.Id : Guid.Empty,
            DiscordID = (isAdmin || u.DiscordUser?.Id.ToString() == discordId) ? u.DiscordUser.Id : 0,
            Name = (u.DiscordUser?.Roles.Any(r => r.Id == 796512753241161748) ?? false ? "🆕" : "") + ebrgx.Replace(u.Name, ""),
            NumChickens = u.NumChickens.ToEggString(),
            Rate = $"{ArgumentsHelper.NumberToString(u.Rate * 60 * 60, false)}/h",
            ProjectedPercent = u.Projected / targetAmount,
            Status = isSolo
                ? (u.Projected < targetAmount ? $"{ArgumentsHelper.NumberToString((targetAmount - u.EggsShipped) / u.TimeLeft.TotalHours, false)}/h" : "")
                : u.TimeLeft.Humanize(precision: 2).ShortenTime(),
            TimeLeft = u.TimeLeft.TotalSeconds,
            EB = u.Backup.EarningsBonus.ToEggString(),
            EBValue = u.Backup.EarningsBonus,
            Locked = !isAdmin,
            SiloTime = u.SiloTimeMinutes / 60,
            Sleep = u.OfflineTime.TotalMinutes > u.SiloTimeMinutes ? $"💤{(u.OfflineTime - TimeSpan.FromMinutes(u.SiloTimeMinutes)).Humanize().ShortenTime()}" : ""
        });
        dynamic model = new {
            Count = ++count,
            CurrentCoop = c.CoopParticipants.Any(x => (x.DiscordUser?.Id ?? 0).ToString() == discordId),
            Users = isSolo ? users.OrderBy(u => u.Name) : users.OrderByDescending(u => u.ProjectedPercent),
            MaxSize = Model.GuildContract.Contract.Details.MaxCoopSize,
            Rate = $"{ArgumentsHelper.NumberToString(c.CoopParticipants.Sum(x => x.Rate) * 60 * 60, false)}/h",
        };
        return model;
    });

    var expiredFarms = Model.CoopsBreakdown.ExpiredFarms.Select(u => new {
        EggIncId = (isAdmin || u.DiscordUser?.Id.ToString() == discordId) ? u.EggIncId : "",
        DatabaseId = (isAdmin || u.DiscordUser?.Id.ToString() == discordId) ? u.DBUser.Id : Guid.Empty,
        Name = (u.DiscordUser?.Roles.Any(r => r.Id == 796512753241161748) ?? false ? "🆕" : "") + ebrgx.Replace(u.Name, ""),
        NumChickens = u.NumChickens.ToEggString(),
        Rate = $"{ArgumentsHelper.NumberToString(u.Rate * 60 * 60, false)}/h",
        ProjectedPercent = u.Projected / targetAmount,
        Status = isSolo
                ? (u.Projected < targetAmount ? $"{ArgumentsHelper.NumberToString((targetAmount - u.EggsShipped) / u.TimeLeft.TotalHours, false)}/h" : "")
                : u.TimeLeft.Humanize(precision: 2).ShortenTime(),
        TimeLeft = u.TimeLeft.TotalSeconds,
        EB = u.Backup.EarningsBonus.ToEggString(),
        EBValue = u.Backup.EarningsBonus,
        Locked = !isAdmin
    });
}
<style>
    #CurrentCoop {
        border-color: #00ff90;
    }

