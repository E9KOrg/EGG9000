@model List<DBUser>
@{
	ViewData["Title"] = "Search";
}

<table>
	<thead>
		<tr>
			<th>Discord User</th>
			<th colspan="99">Egg Inc Usernames</th>
		</tr>
	</thead>
	@foreach (var user in Model) {
		<tr>
			<td>
				<a href="/MyFarms/ViewUser?discordId=@(user.DiscordId)"> @user.DiscordUsername </a>
			</td>
			@foreach (var username in user.Usernames.Split(",")) {
				<td>@username</td>
			}
		</tr>
	}

</table>