@model EGG9000.Site.Controllers.AdminController.IndexViewModel
@using static EGG9000.Common.Helpers.CreateCoopsV2;
@{
	ViewData["Title"] = "Admin";
	var days = Model.Days?.Select(x => new object[] { x.Key.ToUnixTimeMilliseconds(), x.Value[0] });
	var days2 = Model.Days?.Select(x => new object[] { x.Key.ToUnixTimeMilliseconds(), x.Value[1] });
}

@if (User.IsInRole("Admin")) {
	<div style="padding-bottom: 0.75%">
		Super-Admin<br />
		<a href="/admin/editusers" class="btn btn-primary">Edit Users</a>
		<a href="/admin/restartbot" class="btn btn-danger" onclick="return confirm('Are you sure you want to restart the bot?');">Restart Bot</a>
	</div>
}
@if (User.IsInRole("Admin") || User.IsInRole("GuildAdmin") || User.IsInRole("GuildLesserAdmin")) {
	<div style="padding-bottom: 0.75%">
		Customizations<br />
		<a href="/admin/configureserver" class="btn btn-primary">Customize Server</a>
		<a href="/admin/eventcustomization" class="btn btn-primary">Customize Events</a>
		@if (Model.Guild.FAQTopicsEnabled) {
			<a href="/admin/faqcustomization" class="btn btn-primary">Customize FAQ Topics</a>
		}
	</div>
}
<div style="padding-bottom: 0.75%">
	Player Reports<br />
	<a href="/admin/sleepers" class="btn btn-primary">Sleepers</a>
	<a href="/admin/ghosts" class="btn btn-primary">Ghosts</a>
	<a href="/admin/slackers" class="btn btn-primary">Slackers</a>
	<a href="/admin/standardpermit" class="btn btn-primary">Standard Permits</a>
	<a href="/admin/inactiveplayers" class="btn btn-primary">Inactive Players</a>
	<a href="/admin/nonserverusers" class="btn btn-primary">Non-Server Users</a>
</div>
<div style="padding-bottom: 0.75%">
	Server & Bot Management<br />
	<a href="/admin/duplicatechannels" class="btn btn-primary">Duplicate Channels</a>
	<!-- Palace-only -->
	@if (Model.Guild.Id == 656455567858073601) {
		<a href="/admin/easteregghunt" class="btn btn-primary">Easter Egg Hunt</a>
		<a href="/admin/halloweenhunt" class="btn btn-primary">Halloween Egg Hunt</a>
	}
	<a href="/admin/automatedtasks" class="btn btn-primary">Automated Tasks</a>
	<a href="/admin/latestdemerits" class="btn btn-primary">Latest Demerits</a>
	@if (Model.Guild.AllowGuilds) {
		<a href="/admin/guilds" class="btn btn-primary">Guilds</a>
	}
	<a href="/admin/checkcoopcreators" class="btn btn-primary">Check Coop Creators</a>

</div>


<div class="clearfix">
	<div class="float-left card">
		<div class="card-body">
			<h5 class="card-title">
				Server Stats
			</h5>
			<table class="table">
				<thead>
					<tr>
						<th>Server</th>
						<th>Threads</th>
						<th>Active Coops</th>
						<th>🏁 Coops</th>
						<th>Available for Coops</th>
					</tr>
				</thead>
				@{
					var first = true;
					var availableSum = 0;
					foreach (var guild in Model.Guilds) {
						int available;
						if (first) {
							first = false;
							available = Math.Max(PrimaryMaxThreads - guild.ThreadCount, 0);

						} else {
							available = Math.Max(OverflowMaxThreads - guild.ThreadCount, 0);

						}
						availableSum += available;
						<tr>
							<td>@guild.Name</td>
							<td>@guild.ThreadCount</td>
							<td>@guild.ActiveCoops</td>
							<td>@guild.FinishedCoops</td>
							<td>@(available)</td>
						</tr>
					}
				}
				<tr>
					<th colspan="4" align="right">Total Threads Available for Co-ops</th>
					<td>
						@availableSum
					</td>
				</tr>
				<tr>
					<th colspan="4" align="right">Co-ops waiting on thread creation</th>
					<td>
						@Model.CoopsWithoutThreads
					</td>
				</tr>

			</table>
		</div>
	</div>

	<div class="float-left card">
		<div class="card-body">
			<h5 class="card-title">
				Recent Contracts
			</h5>

			@foreach (var contract in Model.Contracts) {
				<div>@*<a href="/admin/contract?contractid=@contract.ID">@contract.Name</a> *@<a href="/admin/contractscores?contractid=@contract.ID">@contract.Name</a></div>
			}
		</div>
	</div>
	@if (Model.ContractsToScore.Count > 0) {
		<div class="float-left card">
			<div class="card-body">
				<h5 class="card-title">
					Contracts Ready to Score
				</h5>

				@foreach (var contract in Model.ContractsToScore.OrderBy(x => x.GoodUntil)) {
					<div><a href="/admin/calculatescore?contractid=@contract.ID">@contract.Name</a> @contract.Created.Add(contract.ContractTime).AddDays(3).ToString("yyyy-MM-dd")</div>
				}
			</div>
		</div>
	}
</div>
<div>
	<div class="btn-group" role="group" style="margin-top: 20px;" id="scopeToggle">
		<button type="button" class="btn btn-outline-primary active" data-scope="global">Global</button>
		<button type="button" class="btn btn-outline-primary" data-scope="server">@Model.Guild.Name</button>
	</div>
	<div id="chart"></div>

</div>

<style>
	.card {
		margin-right: 20px;
		margin-top: 20px;
	}
</style>

<partial name="_ApexCharts" />
@section Scripts {
<script>
	var SERVER_NAME = @Json.Serialize(Model.Guild.Name);
	var COOPS_GLOBAL = "Co-ops (Global)";
	var COOPS_SERVER = "Co-ops (" + SERVER_NAME + ")";
	var USERS_GLOBAL = "Active Users (Global)";
	var USERS_SERVER = "Active Users (" + SERVER_NAME + ")";

	var CHART_DATA = null;

	$.ajax({
        url: "/admin/getgraphs",
        success: function (data) {
            CHART_DATA = data;
            CreateChart(data);
        },
        error: function (xhr) {
            console.error("getgraphs failed:", xhr.status, xhr.responseText);
        }
    });

	function seriesFor(scope, data) {
		if (scope === "server") {
			return [
				{ name: COOPS_SERVER, data: data.guildDays },
				{ name: USERS_SERVER, data: data.guildDays2 }
			];
		}
		return [
			{ name: COOPS_GLOBAL, data: data.days },
			{ name: USERS_GLOBAL, data: data.days2 }
		];
	}

	function CreateChart(data) {
		var options = {
			chart: {
				type: 'area',
				stacked: false,
				zoom: {
					autoScaleYaxis: true
				}
			},
			dataLabels: {
				enabled: false
			},
			series: seriesFor(currentScope(), data),
			yaxis: [{
				seriesName: [COOPS_GLOBAL, COOPS_SERVER],
				opposite: true,
				title: { text: "Number of Co-ops" }
			}, {
				seriesName: [USERS_GLOBAL, USERS_SERVER],
				title: { text: "Number of Active Users" }
			}],
			xaxis: {
				type: 'datetime'
			},
			tooltip: {
				x: {
					format: 'dd MMM yyyy'
				}
			},
			stroke: {
				width: 2
			}
		}

		var chart = new ApexCharts(document.querySelector("#chart"), options);
		chart.render();

		document.querySelectorAll('#scopeToggle button[data-scope]').forEach(function (el) {
			el.addEventListener('click', function () {
				document.querySelectorAll('#scopeToggle button[data-scope]').forEach(function (b) {
					b.classList.remove('active');
				});
				el.classList.add('active');
				chart.updateSeries(seriesFor(currentScope(), CHART_DATA), true);
			});
		});
	}

	function currentScope() {
		var active = document.querySelector('#scopeToggle button[data-scope].active');
		return active ? active.getAttribute('data-scope') : "global";
	}
</script>

}