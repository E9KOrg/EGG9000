<script>
    var options = {
        chart: {
            type: 'scatter',
            zoom: {
                enabled: true,
                type: 'xy'
            }
        },
@*series: [{
        data: @Html.Raw(JsonConvert.SerializeObject(chartData))
    }],*@
        series: @Html.Raw(JsonConvert.SerializeObject(chartData)),
        yaxis: {
        //logarithmic: true
        decimalsInFloat: 2
        },
        xaxis: {
        //logarithmic: true,
        //type: "numeric",
        tickAmount: 10

        //    type: 'datetime'
        },
        //tooltip: {
        //    x: {
        //        format: 'dd MMM yyyy'
        //    }
        //},
        dataLabels: {
        enabled: false
        },
        stroke: {
        width: 2
        },
        legend: {
        show: false
        },
        animations: {
        enabled: false
        }
        }

        var chart = new ApexCharts(document.querySelector("#chart"), options);

        chart.render();
</script>
        }