@using System.Globalization
@model List<EGG9000.Site.Controllers.AdminController.Slacker>

@{
	List<Contract> contracts = ViewBag.Contracts;

	var contractIDs = contracts.OrderByDescending(x => x.GoodUntil).Select(x => x.ID);
	contractIDs = contractIDs.Where(c => Model.Any(s => s.UserCoopXrefs.Any(x => c == x.ContractID && x.Score.HasValue))).ToList();
	var threshold = EGG9000.Site.Controllers.AdminController.scoreThreshold;


	string GetClass(float score) {
		return score > 1e-1 ? "bg-success" : score > threshold ? "bg-warning" : "bg-danger";
	}
}
<p>
	<ul>
		<li>Red is running score below @threshold.ToString("#.#########") (@Math.Round(Math.Log10(threshold),1))</li>
		<li>Yellow is running score below 0.1</li>
		<li>Gray means there haven't been enough contracts yet for running score (a running score will always be the average of 3 contracts)</li>
		<li>The score is the small number in the bottom right</li>
		<li>The running score contracts are in different orders for different people</li>
		<li>If the first two columns are gray it means they haven't had a score in a month</li>
	</ul>
</p>
<button type="button" onclick="$('tr:not(.current)').toggle()">Toggle currently below threshold</button>
<table class="table">
	<thead>
		<tr>
			<th>User</th>
			<th>Last Score</th>
		</tr>
	</thead>
	<tbody>
		@foreach(var slacker in Model.OrderBy(x => x.DiscordUsername)) {
			var xrefs = slacker.UserCoopXrefs.Where(x => x.Score.HasValue).OrderByDescending(x => x.Date);
			var lastContractTime = DateTimeOffset.Now - xrefs.First().Date;
			var longTime = lastContractTime.TotalDays > 35;
			var firstXrefWithRunning = xrefs.First(x => x.RunningScore.HasValue);
			<tr class="@(firstXrefWithRunning.RunningScore < threshold ? "current" : "")">
					<td style="white-space: nowrap" class="@(longTime ? "bg-secondary" : (firstXrefWithRunning.RunningScore < threshold ? "bg-danger" : "" ))">@slacker.DiscordUsername</td>
					<td  class="@(longTime ? "bg-secondary" : "")">@(lastContractTime.Humanize())</td>
				@foreach(var xref in xrefs.Take(20)) {
					if (xref?.RunningScore != null) {
						<td style="position: relative;" class="@GetClass(xref.RunningScore.Value)">@Math.Round(Math.Log10((double)xref.RunningScore.Value),1)
						<span style="position: absolute; right: 0; bottom: 0; left: 0; font-size: 70%" class="@(xref.Score.Value)">@Math.Round(Math.Log10((double)xref.Score.Value),1)</span>
						</td>
					} else if(xref?.Score != null) {
						<td style="position: relative;" class="bg-secondary">
							<span style="position: absolute; right: 0; bottom: 0; left: 0; font-size: 70%" class="@(xref.Score.Value)">@Math.Round(Math.Log10((double)xref.Score.Value),1)</span>
						</td>
					} else {
						<td></td>
					}

				}
			</tr>
		}
	</tbody>
</table>

<style>
	.container {
		max-width:unset !important;

	}

	.bootstrap-dark .bg-warning {
		color: #333;
	}
</style>