<?xml version="1.0" encoding="utf-8" ?>
<!-- XSD manual extracted from package NLog.Schema: https://www.nuget.org/packages/NLog.Schema-->
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xmlns:sl="http://www.nlog-project.org/schemas/NLog.Targets.Syslog.xsd"
      autoReload="true"
      internalLogLevel="Off" >

  <extensions>
    <add assembly="NLog.Targets.Network"/>
  </extensions>
  <!-- the targets to write to -->
  <targets async="true">
    <target xsi:type="Syslog" name="syslog"
        address="tcp://logs3.papertrailapp.com:22236"
        SyslogMessage ="${logger:shortName=true:truncate=15}|${message} ${exception:format=tostring}"
        SyslogHostName="${gdc:item=CustomMachineName}"
        SyslogAppName="${gdc:item=CustomAppName}">
    </target>
    <target xsi:type="ColoredConsole" name="logconsole"
            layout="${date:format=yyyy-MM-dd HH\:mm\:ss}|${level:uppercase=true:truncate=4}|${logger:shortName=true:padding=15:truncate=15}|${message} ${exception:format=tostring}">
    </target>
  </targets>

  <!-- rules to map from logger name to target -->
  <rules>
    <logger name="*" minlevel="Information" writeTo="syslog">
      <filters defaultAction='Log'>
        <when condition="contains('${message}','Rate limit triggered')" action="Ignore" />
        <when condition="contains('${message}','Executed DbCommand')" action="Ignore" />
      </filters>
    </logger>
    <logger name="*" minlevel="Trace" writeTo="logconsole">
      <filters defaultAction='Log'>
        <when condition="'${logger:shortName=true}' == 'Command'" action="Ignore" />
        <when condition="'${logger:shortName=true}' == 'ChangeTracking'" action="Ignore" />
        <when condition="'${logger:shortName=true}' == 'Connection'" action="Ignore" />
        <when condition="'${logger:shortName=true}' == 'Model'" action="Ignore" />
        <when condition="'${logger:shortName=true}' == 'Query'" action="Ignore" />
        <when condition="'${logger:shortName=true}' == 'Infrastructure'" action="Ignore" />
        <when condition="'${logger:shortName=true}' == 'Update'" action="Ignore" />
        <when condition="'${logger:shortName=true}' == 'Transaction'" action="Ignore" />
      </filters>
    </logger>
  </rules>
</nlog>