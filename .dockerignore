# Build output - the main culprit for large contexts
**/bin/
**/obj/

# Publish artifacts
artifacts/

# Git
.git/
.gitignore

# Docker files (not needed inside image)
Dockerfile*
docker-compose*
.dockerignore

# Visual Studio / Rider
.vs/
.vscode/
.idea/
*.suo
*.user
*.userprefs
*.sln.iml

# Logs
logs/
*.log

# Node
node_modules/
npm-debug.log

# OS
.DS_Store
.bash_history

# Secrets / certs (never send to Docker daemon)
*.pem
*.pfx
*.pub
secrets.json

# Misc generated
*.cache
*.out
*.lock.json
*.pdb
*.ilk
_sass/
.sass-cache/
.nuget/
.npm/
